---
import Base from '@/layouts/Base.astro';
import RecordCard from '@/components/RecordCard.astro';
import { allRecords, stats, domainsPresent, loadCatalog } from '@/lib/store';
import { DOMAIN_LABEL } from '@/lib/display';
import type { Domain } from '@/types';

const records = allRecords();
const s = stats();
const present = domainsPresent();
const allDomains: Domain[] = ['orbital', 'neo', 'space_weather', 'launch_reentry'];
const base = import.meta.env.BASE_URL;
const catalogCount = loadCatalog().length;
---

<Base title="Dragon Lady’s Observatory">
  <!-- celestial hero -->
  <section class="sky -mx-4 mb-6 rounded-none border-b border-void-800 px-4 py-10 sm:rounded-xl sm:border">
    <div class="relative z-10 max-w-2xl">
      <h1 class="text-2xl font-semibold tracking-tight text-mist-100 sm:text-3xl">The sky, watched.</h1>
      <p class="mt-1 text-xs text-mist-500">Your personal observatory in the night sky.</p>
      <p class="mt-3 text-mist-300">
        A calm place to explore what’s overhead — satellites, stars, and quiet moments worth noticing.
      </p>
      <div class="mt-5 flex flex-wrap gap-4 text-sm text-mist-400">
        <span><strong class="text-mist-100">{s.total}</strong> things overhead</span>
        <span><strong class="text-mist-100">{s.anomalies}</strong> quiet moments saved</span>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={base + 'globe'} class="inline-flex items-center gap-2 rounded-md bg-signal-400 px-5 py-2.5 text-sm font-semibold !text-void-950 hover:!no-underline hover:bg-signal-300">
          🌍 Open the globe
        </a>
        <a href={base + 'sky-events'} class="inline-flex items-center gap-2 rounded-md border border-void-700 px-5 py-2.5 text-sm font-medium text-mist-200 hover:bg-emerald-900/20 hover:border-emerald-700 hover:text-emerald-300 transition-colors">
          ✨ Explore the sky events
        </a>
      </div>
    </div>
  </section>

  <!-- Your Observatory (primary personal experience) -->
  <section class="mb-8">
    <div class="mb-4">
      <h2 class="text-xl font-semibold text-mist-100">Your observatory</h2>
      <p class="text-xs text-mist-500 mt-0.5">The places in the sky that matter to you.</p>
    </div>

    <!-- My Pins Section -->
    <div class="mb-6">
      <!-- Collection Filter Chips -->
      <div class="mb-3 flex flex-wrap gap-2" id="pins-chips">
        <button data-chip="all" class="chip active px-3 py-1 text-sm rounded-full border border-signal-400 bg-void-800 text-mist-100">All moments</button>
        <button data-chip="favorites" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">Favorites shelf</button>
        <button data-chip="sky-events" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">From Sky Events</button>
        <button data-chip="quiet" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">Quiet revisit</button>
      </div>
      <div id="chip-hint" class="hidden mb-3 text-xs text-mist-400"></div>

      <!-- Vault Migration Banner -->
      <div id="vault-banner" class="hidden mb-4 rounded-xl border border-void-700 bg-void-900 p-5" onclick="event.stopImmediatePropagation()">
        <div class="text-mist-200 mb-3">You have a backup of your pins in the vault. Would you like to bring them into this browser?</div>
        <div class="flex gap-3">
          <button id="bring-home" class="px-4 py-1.5 text-sm rounded-lg bg-signal-400 text-void-950 font-medium">Bring them home</button>
          <button id="not-now" class="px-4 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300">Not now</button>
        </div>
      </div>

      <div class="mb-4 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <input id="pins-search" type="text" placeholder="Find a saved view..."
                 class="text-sm px-3 py-1.5 rounded-lg border border-void-700 bg-void-900 text-mist-200 placeholder:text-mist-500 focus:outline-none focus:border-void-500" style="width:180px;">
          <button id="clear-search" class="text-xs text-mist-500 hover:text-mist-300">clear</button>
          <select id="pins-sort" class="text-sm px-3 py-1.5 rounded-lg border border-void-700 bg-void-900 text-mist-200 focus:outline-none focus:border-void-500">
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="favorites">Favorites first</option>
          </select>
        </div>
        <div class="flex gap-2">
          <button id="export-pins" class="px-3 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300 hover:bg-void-800">Export my pins</button>
          <label class="px-3 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300 hover:bg-void-800 cursor-pointer">
            Import pins
            <input type="file" id="import-pins" accept=".json" class="hidden" />
          </label>
        </div>
      </div>

      <div id="pins-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Populated by script below -->
      </div>

      <div id="pins-empty" class="hidden rounded-xl border border-dashed border-void-700 p-8 text-center">
        <p class="text-mist-300">No pins yet. Open the globe and press <strong>P</strong> on anything beautiful.</p>
      </div>

      <div id="pins-no-results" class="hidden col-span-full text-center text-mist-400 text-sm py-6">
        No pins match your search.
      </div>
    </div>
  </section>

  <!-- Sky Events teaser -->
  <section class="mb-8">
    <a href={base + 'sky-events'} class="block rounded-2xl border border-void-700 bg-void-900 p-6 hover:border-void-500 transition-colors">
      <div class="flex items-center justify-between">
        <div>
          <div class="font-medium text-mist-100 text-lg">Sky Events</div>
          <p class="mt-1 text-sm text-mist-300">Constellations and quiet moments worth noticing tonight and soon.</p>
        </div>
        <span class="text-signal-400 text-sm">Explore →</span>
      </div>
    </a>
  </section>

  <!-- Everything overhead (optional) — collapsed by default -->
  <details class="mb-6">
    <summary class="cursor-pointer text-sm text-mist-400 hover:text-mist-200 mb-4 select-none">
      Everything overhead (optional)
    </summary>

    <!-- layer toggles + tier legend (de-emphasized) -->
    <div class="mb-4 flex flex-wrap items-center justify-between gap-3 opacity-85">
      <div class="flex flex-wrap items-center gap-2">
        <button class="layer-btn active rounded-full border border-signal-400 bg-void-800 px-3 py-1 text-sm !text-mist-100" data-layer="all">All</button>
        {allDomains.map((d) => (
          <button
            class="layer-btn rounded-full border border-void-700 bg-void-900 px-3 py-1 text-sm text-mist-300 disabled:opacity-40"
            data-layer={d}
            disabled={!present.includes(d)}
            title={present.includes(d) ? '' : 'no data yet'}
          >{DOMAIN_LABEL[d]}</button>
        ))}
      </div>
      <div class="flex items-center gap-3 text-xs text-mist-400/80" title="Tiers reflect interest level, not urgency.">
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t1"></span>T1</span>
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t2"></span>T2</span>
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t3"></span>T3</span>
      </div>
    </div>

    <!-- browse-catalog hatch (softened) -->
    <a href={base + 'catalog'} class="mb-4 flex items-center justify-between rounded-lg border border-void-800 bg-void-900 px-4 py-3 text-sm hover:border-void-600 hover:!no-underline opacity-85">
      <span class="!text-mist-200">🛰 Browse everything up there — <strong class="text-mist-100">{catalogCount.toLocaleString()}</strong> things overhead</span>
      <span class="text-signal-400">search →</span>
    </a>

    {records.length === 0 ? (
      <div class="rounded-lg border border-dashed border-void-700 p-8 text-center">
        <p class="text-mist-300">The sky feels quiet right now. Take your time exploring.</p>
      </div>
    ) : (
      <div id="grid" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {records.map((r) => <RecordCard record={r} />)}
      </div>
    )}

    <script is:inline>
      const btns = document.querySelectorAll('.layer-btn');
      const cards = document.querySelectorAll('.record-card');
      btns.forEach((b) => b.addEventListener('click', () => {
        const layer = b.dataset.layer;
        btns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('active', on);
          x.classList.toggle('border-signal-400', on);
          x.classList.toggle('!text-mist-100', on);
          x.classList.toggle('border-void-700', !on);
          x.classList.toggle('text-mist-300', !on);
        });
        cards.forEach((c) => {
          c.style.display = (layer === 'all' || c.dataset.domain === layer) ? '' : 'none';
        });
      }));
    </script>
  </details>

  <script is:inline define:vars={{ base }}>
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;',
  }[char]));

  const safeNumber = (value, fallback = 0) => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  };

  let activeChip = 'all';

  function getDaysSince(dateStr) {
    if (!dateStr) return 9999;
    return Math.floor((Date.now() - new Date(dateStr).getTime()) / (1000 * 60 * 60 * 24));
  }

  function applyCollectionFilter(pins, chip) {
    if (chip === 'all') return pins;
    if (chip === 'favorites') return pins.filter(p => p.favorite);
    if (chip === 'sky-events') return pins.filter(p => p.sourceEventId);
    if (chip === 'quiet') {
      return pins.filter(p => {
        const date = p.updatedAt || p.createdAt;
        return getDaysSince(date) > 30;
      });
    }
    return pins;
  }

  function renderMyPins() {
    const grid = document.getElementById('pins-grid');
    const empty = document.getElementById('pins-empty');
    const noResults = document.getElementById('pins-no-results');
    const hint = document.getElementById('chip-hint');

    let pins = [];
    try {
      pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
    } catch {
      pins = [];
    }

    const searchInput = document.getElementById('pins-search');
    const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';

    const sortSelect = document.getElementById('pins-sort');
    const sortMode = sortSelect ? sortSelect.value : 'newest';

    // Filter pipeline: collection chip first, then search, then sort
    let filtered = applyCollectionFilter(pins, activeChip);

    if (searchTerm) {
      filtered = filtered.filter(p =>
        String(p.label || '').toLowerCase().includes(searchTerm) ||
        (p.note && String(p.note).toLowerCase().includes(searchTerm))
      );
    }

    let sorted = [...filtered];
    if (sortMode === 'newest') {
      sorted.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
    } else if (sortMode === 'oldest') {
      sorted.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
    } else if (sortMode === 'favorites') {
      sorted.sort((a, b) => (b.favorite ? 1 : 0) - (a.favorite ? 1 : 0) || new Date(b.createdAt) - new Date(a.createdAt));
    }

    grid.innerHTML = '';

    // Chip hint
    if (activeChip !== 'all') {
      const messages = {
        favorites: 'Your starred views',
        'sky-events': 'Moments you pinned from events',
        quiet: 'Some views wait patiently for you.'
      };
      hint.textContent = messages[activeChip] || '';
      hint.classList.remove('hidden');
    } else {
      hint.classList.add('hidden');
    }

    if (pins.length === 0) {
      empty.classList.remove('hidden');
      noResults.classList.add('hidden');
      return;
    }

    empty.classList.add('hidden');

    if (sorted.length === 0 && searchTerm) {
      noResults.classList.remove('hidden');
      return;
    } else {
      noResults.classList.add('hidden');
    }

    sorted.forEach((pin) => {
      const card = document.createElement('div');
      const isFromSky = !!pin.sourceEventId;
      card.className = `group rounded-xl border border-void-700 bg-void-900 p-5 hover:border-void-500 hover:-translate-y-0.5 transition-all duration-200 shadow-sm cursor-pointer ${isFromSky ? 'border-l-2 border-l-emerald-700' : ''}`;

      // Thumbnail (real or gradient fallback)
      let thumbHTML = '';
      const viewState = pin.viewState || {};
      const lat = safeNumber(viewState.lat);
      const lng = safeNumber(viewState.lng);
      const altitude = safeNumber(viewState.altitude, 2.8);
      const label = escapeHtml(pin.label || 'Untitled Pin');
      const note = pin.note ? escapeHtml(pin.note) : '';

      if (pin.thumbnailData) {
        thumbHTML = `<img src="${escapeHtml(pin.thumbnailData)}" class="w-[52px] h-[38px] rounded-md object-cover flex-shrink-0 border border-void-700" />`;
      } else {
        const hue = Math.floor(((lat + 90) / 180) * 360);
        const sat = 38 + Math.floor(Math.abs(lng) % 35);
        const light = 32 + Math.floor(Math.abs(lat) % 18);
        thumbHTML = `<div style="width:52px;height:38px;border-radius:6px;background:linear-gradient(135deg, hsl(${hue},${sat}%,${light}%), hsl(${hue+30},${sat+10}%,${light-8}%));flex-shrink-0;border:1px solid #36415a;"></div>`;
      }

      const lastViewed = pin.updatedAt 
        ? `Last viewed ${Math.floor((Date.now() - new Date(pin.updatedAt).getTime()) / (1000*60*60*24))} days ago`
        : `Pinned ${new Date(pin.createdAt).toLocaleDateString()}`;

      card.innerHTML = `
        <div class="flex justify-between items-start">
          <div class="flex items-center gap-2 min-w-0">
            ${thumbHTML}
            <div class="min-w-0">
              <div class="font-medium text-mist-100 pin-label cursor-pointer hover:underline flex items-center gap-1.5">
                ${label}
                ${pin.favorite ? `<span class="text-yellow-400 text-sm">★</span>` : ''}
              </div>
              <div class="text-[10px] text-mist-500 mt-0.5">${lastViewed}</div>
            </div>
          </div>
          <div class="flex items-center gap-1">
            <button class="edit-btn text-xs px-2 py-0.5 rounded border border-void-600 text-mist-400 hover:text-mist-200" data-id="${pin.id}">Edit</button>
            <button class="favorite-btn text-lg leading-none transition-colors ${pin.favorite ? 'text-yellow-400' : 'text-mist-400 hover:text-yellow-300'}" data-id="${pin.id}">★</button>
            <button class="delete-pin text-mist-400 hover:text-red-400/80 text-xl leading-none transition-colors" data-id="${pin.id}">×</button>
          </div>
        </div>
        ${note ? `<div class="mt-3 text-sm text-mist-300 pin-note cursor-pointer hover:underline line-clamp-2">${note}</div>` : ''}
        ${isFromSky ? `<div class="mt-2 text-[10px] text-emerald-400/70">from Sky Events</div>` : ''}
        <div class="mt-3 text-[10px] text-mist-500">lat ${lat.toFixed(2)} · lng ${lng.toFixed(2)}</div>
        <div class="edit-panel hidden mt-4 border-t border-void-700 pt-4"></div>
      `;

      // Click card → fly to view on globe + pass pin identity
      card.addEventListener('click', (e) => {
        if (e.target.classList.contains('delete-pin') || 
            e.target.classList.contains('favorite-btn') ||
            e.target.classList.contains('edit-btn')) return;

        // Pass both the viewState and the specific pin ID so the globe knows exactly which pin we're viewing
        localStorage.setItem('flyToPin', JSON.stringify({
          id: pin.id,
          viewState: { lat, lng, altitude }
        }));
        window.location.href = base + 'globe';
      });

      // Delete
      card.querySelector('.delete-pin').addEventListener('click', (e) => {
        e.stopImmediatePropagation();
        if (!confirm('Remove this pin?')) return;
        const updated = pins.filter(p => p.id !== pin.id);
        localStorage.setItem('personalPins', JSON.stringify(updated));
        renderMyPins();
      });

      // Favorite toggle
      const favBtn = card.querySelector('.favorite-btn');
      if (favBtn) {
        favBtn.addEventListener('click', (e) => {
          e.stopImmediatePropagation();
          pin.favorite = !pin.favorite;
          const updated = pins.map(p => p.id === pin.id ? pin : p);
          localStorage.setItem('personalPins', JSON.stringify(updated));
          renderMyPins();
        });
      }

      // Edit button opens inline panel
      const editBtn = card.querySelector('.edit-btn');
      const editPanel = card.querySelector('.edit-panel');

      editBtn.addEventListener('click', (e) => {
        e.stopImmediatePropagation();
        editPanel.innerHTML = `
          <div class="space-y-3">
            <input type="text" value="${escapeHtml(pin.label || '')}" class="edit-label w-full px-3 py-2 rounded-lg border border-void-700 bg-void-950 text-mist-100 text-sm" />
            <textarea class="edit-note w-full px-3 py-2 rounded-lg border border-void-700 bg-void-950 text-mist-100 text-sm" rows="3">${escapeHtml(pin.note || '')}</textarea>
            <div class="flex gap-2">
              <button class="save-edit px-4 py-1.5 text-sm rounded-lg bg-signal-400 text-void-950 font-medium">Save</button>
              <button class="cancel-edit px-4 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300">Cancel</button>
            </div>
          </div>
        `;
        editPanel.classList.remove('hidden');

        const saveBtn = editPanel.querySelector('.save-edit');
        const cancelBtn = editPanel.querySelector('.cancel-edit');

        saveBtn.addEventListener('click', () => {
          const newLabel = editPanel.querySelector('.edit-label').value.trim();
          const newNote = editPanel.querySelector('.edit-note').value.trim();
          if (newLabel) pin.label = newLabel;
          pin.note = newNote || undefined;
          const updated = pins.map(p => p.id === pin.id ? pin : p);
          localStorage.setItem('personalPins', JSON.stringify(updated));
          renderMyPins();
        });

        cancelBtn.addEventListener('click', () => {
          editPanel.classList.add('hidden');
          editPanel.innerHTML = '';
        });
      });

      grid.appendChild(card);
    });
  }

  async function checkVaultAndShowBanner() {
    const banner = document.getElementById('vault-banner');
    if (!banner || localStorage.getItem('vaultMigrationBannerDismissed')) return;

    try {
      // Lightweight read endpoint (minimal for this slice)
      const res = await fetch('/api/vault-pins');
      if (!res.ok) return;

      const vaultData = await res.json();
      if (!Array.isArray(vaultData.pins) || vaultData.pins.length === 0) return;

      const localPins = JSON.parse(localStorage.getItem('personalPins') || '[]');
      const latestLocal = localPins.reduce((max, p) => {
        const d = new Date(p.updatedAt || p.createdAt || 0);
        return d > max ? d : max;
      }, new Date(0));
      const vaultNewer = vaultData.lastSynced && (!localPins.length || new Date(vaultData.lastSynced) > latestLocal);

      if (vaultNewer || localPins.length === 0) {
        banner.classList.remove('hidden');

        document.getElementById('bring-home').onclick = (e) => {
          e.stopImmediatePropagation();
          let current = JSON.parse(localStorage.getItem('personalPins') || '[]');
          const existingIds = new Set(current.map(p => p.id));
          let added = 0;

          vaultData.pins.forEach(pin => {
            if (pin && pin.id && !existingIds.has(pin.id)) {
              current.push(pin);
              existingIds.add(pin.id);
              added++;
            }
          });

          localStorage.setItem('personalPins', JSON.stringify(current));
          localStorage.setItem('vaultMigrationBannerDismissed', 'true');
          banner.classList.add('hidden');
          renderMyPins();
        };

        document.getElementById('not-now').onclick = (e) => {
          e.stopImmediatePropagation();
          localStorage.setItem('vaultMigrationBannerDismissed', 'true');
          banner.classList.add('hidden');
        };
      }
    } catch (e) {
      // Vault endpoint not available yet — silent fail for this slice
    }
  }

  function setupMyPins() {
    // Chip handling
    const chips = document.querySelectorAll('#pins-chips .chip');
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const chipType = chip.dataset.chip;
        if (activeChip === chipType) {
          activeChip = 'all';
          chips.forEach(c => c.classList.remove('active', 'border-signal-400', 'bg-void-800'));
          chips[0].classList.add('active', 'border-signal-400', 'bg-void-800');
        } else {
          activeChip = chipType;
          chips.forEach(c => c.classList.remove('active', 'border-signal-400', 'bg-void-800'));
          chip.classList.add('active', 'border-signal-400', 'bg-void-800');
        }
        renderMyPins();
      });
    });

    // Export
    const exportBtn = document.getElementById('export-pins');
    if (exportBtn) {
      exportBtn.addEventListener('click', () => {
        const pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
        const date = new Date().toISOString().split('T')[0];
        const blob = new Blob([JSON.stringify(pins, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `dragon-lady-pins-${date}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      });
    }

    // Import
    const importInput = document.getElementById('import-pins');
    if (importInput) {
      importInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (event) => {
          try {
            const imported = JSON.parse(event.target.result);
            if (!Array.isArray(imported)) {
              alert('File does not contain a valid pins array.');
              return;
            }

            let current = [];
            try {
              current = JSON.parse(localStorage.getItem('personalPins') || '[]');
            } catch {}

            const existingIds = new Set(current.map(p => p.id));
            let added = 0;

            imported.forEach(pin => {
              if (pin && pin.id && !existingIds.has(pin.id)) {
                current.push(pin);
                existingIds.add(pin.id);
                added++;
              }
            });

            localStorage.setItem('personalPins', JSON.stringify(current));
            renderMyPins();

            const msg = added === 1 ? '1 pin imported' : `${added} pins imported`;
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #36415a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);

          } catch (err) {
            alert('Could not read the file. Please make sure it is a valid pins backup.');
          }
        };
        reader.readAsText(file);
        e.target.value = '';
      });
    }

    renderMyPins();
    checkVaultAndShowBanner();

    const searchInput = document.getElementById('pins-search');
    const clearBtn = document.getElementById('clear-search');
    const sortSelect = document.getElementById('pins-sort');

    if (searchInput) {
      searchInput.addEventListener('input', () => renderMyPins());
    }

    if (clearBtn && searchInput) {
      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        renderMyPins();
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', () => renderMyPins());
    }
  }

  setupMyPins();
  </script>
</Base>
