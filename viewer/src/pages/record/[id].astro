---
import Base from '@/layouts/Base.astro';
import { allRecords, recordById } from '@/lib/store';
import { primaryName } from '@/types';
import { tierClass, tierDot, TIER_LABEL, DOMAIN_LABEL, placeLabel } from '@/lib/display';

export const prerender = true;

export async function getStaticPaths() {
  return allRecords().map((r) => ({ params: { id: r.id }, props: { record: r } }));
}
const { record: r } = Astro.props;
const base = import.meta.env.BASE_URL;
const loc = r.location as Record<string, any>;
const locEntries = Object.entries(loc).filter(([, v]) => v !== null && v !== '' && typeof v !== 'object');
const staleClass = r.freshness.staleness_risk === 'high' ? 'tier-t1' : r.freshness.staleness_risk === 'medium' ? 'tier-t2' : 'text-mist-300';
---
<Base title={primaryName(r)} description={r.description}>
  <nav class="mb-4 text-sm text-mist-400"><a href={base}>Sky</a> / {DOMAIN_LABEL[r.domain]} / <span class="text-mist-300">{primaryName(r)}</span></nav>

  <header class="mb-5">
    <div class="mb-2 flex flex-wrap items-center gap-3 text-sm">
      <span class="flex items-center gap-1.5 font-medium">
        <span class={`inline-block h-2.5 w-2.5 rounded-full ${tierDot(r.tier)}`}></span>
        <span class={tierClass(r.tier)}>{TIER_LABEL[r.tier]}</span>
      </span>
      <span class="text-mist-400">{DOMAIN_LABEL[r.domain]} · {placeLabel(r)}</span>
    </div>
    <h1 class="text-2xl font-semibold leading-tight text-mist-100">{primaryName(r)}</h1>
    <p class="mt-1 text-mist-300">{r.description}</p>
    {r.topics.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1">
        {r.topics.map((t) => <span class="rounded bg-void-800 px-1.5 py-0.5 text-[11px] text-mist-300">{t.replace(/_/g, ' ')}</span>)}
      </div>
    )}
    <button id="watch-btn" data-id={r.id} data-name={primaryName(r)} class="mt-3 rounded-md border border-void-700 bg-void-800 px-3 py-1.5 text-sm text-mist-100 hover:border-signal-400">★ Watch</button>
  </header>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_19rem]">
    <div class="space-y-6">
      {r.anomalies.length > 0 ? (
        <section>
          <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-mist-400">Anomalies</h2>
          <div class="space-y-3">
            {r.anomalies.map((a) => (
              <div class="rounded-lg border border-void-800 bg-void-900 p-4">
                <div class="flex items-center justify-between gap-2">
                  <span class={`font-medium ${tierClass(r.tier)}`}>⚠ {a.kind.replace(/_/g, ' ')}</span>
                  <span class="text-xs text-mist-400">confidence {Math.round(a.confidence * 100)}% · {a.state}</span>
                </div>
                <ul class="mt-2 space-y-1.5 text-sm text-mist-200">
                  {a.evidence.map((e) => (
                    <li class="flex gap-2">
                      <span class="text-signal-400">·</span>
                      <span>{e.reason}{e.source_ref && <span class="text-mist-400"> — {e.source_ref}{e.observed_at ? `, ${e.observed_at}` : ''}</span>}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      ) : (
        <section class="rounded-lg border border-void-800 bg-void-900 p-4 text-sm text-mist-400">
          No anomalies on this object — nominal / baseline catalog entry.
        </section>
      )}

      <section>
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-mist-400">Details</h2>
        <dl class="grid grid-cols-1 gap-x-4 gap-y-2 text-sm sm:grid-cols-[auto_1fr]">
          {locEntries.map(([k, v]) => (<>
            <dt class="text-mist-400">{k.replace(/_/g, ' ')}</dt>
            <dd class="break-all text-mist-200">{String(v)}</dd>
          </>))}
        </dl>
      </section>
    </div>

    <aside class="space-y-4">
      <section class="rounded-lg border border-void-800 bg-void-900 p-4">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-mist-400">Provenance</h2>
        <dl class="space-y-2 text-sm">
          <div><dt class="text-mist-400">Last update</dt><dd class="text-mist-200">{r.freshness.last_update}</dd></div>
          <div><dt class="text-mist-400">Staleness</dt><dd class={staleClass}>{r.freshness.staleness_risk}</dd></div>
          {r.sources.map((src) => (
            <div>
              <dt class="text-mist-400">Source</dt>
              <dd><a href={src.url} target="_blank" rel="noopener noreferrer">{src.name} ↗</a> <span class="text-mist-400 text-xs">{src.retrieved_at}</span></dd>
            </div>
          ))}
        </dl>
      </section>
    </aside>
  </div>

  <script is:inline>
    const KEY = 'stars_watchlist';
    const btn = document.getElementById('watch-btn');
    const read = () => { try { return JSON.parse(localStorage.getItem(KEY) || '{}'); } catch { return {}; } };
    const sync = () => { const has = btn.dataset.id in read(); btn.textContent = has ? '★ Watching' : '★ Watch'; btn.classList.toggle('border-signal-400', has); };
    btn.addEventListener('click', () => { const w = read(); const id = btn.dataset.id; if (id in w) delete w[id]; else w[id] = btn.dataset.name; localStorage.setItem(KEY, JSON.stringify(w)); sync(); });
    sync();
  </script>
</Base>
