---
import Base from '@/layouts/Base.astro';
const base = import.meta.env.BASE_URL;
// Camera candidates are intentionally disabled in the live telescope until a source is vetted
// as actual sky/space imagery. Current candidates were fisheye/ground-level and broke the mood.
// The full wiring (selector tabs logic, prominent camera panel, image + video support,
// per-source refresh, localStorage, dim/restore of procedural stage) is preserved below
// as a lab/candidate. Do not show tabs or auto-activate cameras until good vetted sources arrive.
// Goldwing disabled for now; Tanya will hunt + manually verify real sky/space feeds.
const cameraSources = [];
---

<Base title="Telescope · Dragon Lady’s Observatory">
  <div id="main-root" class="fixed inset-0 bg-[#05070d] overflow-hidden">
    <!-- Subtle header -->
    <div class="absolute top-0 left-0 right-0 z-20 px-6 py-4 flex items-center justify-between border-b border-white/10 bg-[#05070d]/80 backdrop-blur-md">
      <div class="flex items-center gap-3">
        <a href={base} class="text-mist-400 hover:text-mist-200 text-sm">← back to observatory</a>
        <div class="text-mist-100 font-semibold tracking-tight text-lg">Telescope</div>
      </div>
      <!-- Eyepiece / spectrum selector (Oracle-style multi-view) -->
      <div id="view-modes" class="flex items-center gap-1.5" role="tablist" aria-label="Observing spectrum"></div>
    </div>

    <!-- Camera selector tabs - horizontal row directly below header (per cottage spec) -->
    <!-- Bigger, touch-friendly tabs for the live cameras. Replaces small toggle. -->
    <!-- Tabs rendered server-side from cameraSources for immediate visibility; JS enhances with clicks and state. -->
    <!-- DISABLED: class includes "hidden". Goldwing disabled the UI until vetted sky/space sources. Wiring preserved. -->
    <div id="live-cam-selector" class="hidden absolute left-0 right-0 z-25 px-6 py-2 bg-[#05070d]/95 border-b border-white/10"
         style="top: 57px;">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-2 overflow-x-auto pb-1">
          {cameraSources.map((s, i) => (
            <button
              type="button"
              data-cam-id={s.id}
              class={`px-3.5 py-1.5 text-xs rounded-full border transition-all whitespace-nowrap flex-shrink-0 text-mist-300 border-white/10 hover:border-white/30 hover:text-mist-100 ${i === 0 ? 'bg-amber-500/30 text-amber-50 border-amber-400/50' : ''}`}
            >
              {s.name}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- The actual telescope view -->
    <div id="telescope-stage" class="absolute inset-0 pt-16 pb-[calc(7rem+env(safe-area-inset-bottom))]">
      <canvas id="telescope-canvas" class="cursor-grab active:cursor-grabbing block w-full h-full"></canvas>
      <!-- Eyepiece ring (depth beyond flat canvas) — live multi-layer parallax + volumetric gas -->
      <div class="pointer-events-none absolute inset-0 rounded-[50%] shadow-[inset_0_0_120px_40px_rgba(0,0,0,0.75)]" aria-hidden="true"></div>
      <div id="eyepiece-tint" class="pointer-events-none absolute inset-0 mix-blend-soft-light opacity-0 transition-opacity duration-500" aria-hidden="true"></div>
    </div>

    <!-- Overlay controls -->
    <div id="telescope-controls" class="absolute left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-3 bottom-[calc(2rem+env(safe-area-inset-bottom))]">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span id="mode-badge" class="px-2.5 py-0.5 rounded-full bg-white/10 text-mist-200 text-[10px] tracking-wide border border-white/15"></span>
        <span id="phase-badge" class="px-2.5 py-0.5 rounded-full bg-white/5 text-mist-400 text-[10px] tracking-wide border border-white/10"></span>
        <div id="pointing-info" class="text-mist-400 text-sm font-mono tracking-widest bg-black/40 px-4 py-1 rounded-full border border-white/10">
          Pointing · RA 00h 00m · Dec +00°
        </div>
      </div>

      <button 
        id="pin-button"
        class="px-8 py-3 rounded-2xl bg-mist-100 text-void-950 font-semibold text-sm tracking-wide hover:bg-white active:scale-[0.985] transition-all flex items-center gap-2 shadow-xl"
      >
        <span>Pin this view</span>
        <span class="text-xs opacity-60">P</span>
      </button>
      <div class="text-[10px] text-mist-500">Capture a quiet moment in the sky</div>
    </div>

    <!-- Mode description -->
    <div class="absolute top-20 right-6 z-20 text-right max-w-[200px]">
      <div id="mode-desc" class="text-[11px] text-mist-300 leading-snug"></div>
      <div class="mt-2 text-[10px] text-mist-500 leading-tight">
        Drag to pan · Wheel to zoom · 1–5 eyepiece · 6-0 sky time
      </div>
    </div>

    <!-- Named targets (so you can actually go to Orion, the Moon, etc.) -->
    <div class="absolute left-6 top-24 z-30 w-44 text-sm">
      <div class="text-mist-400 text-[10px] uppercase tracking-widest mb-2 px-1">Jump to</div>
      <div id="targets" class="flex flex-col gap-1"></div>
    </div>

    <!-- Live Camera View (main camera view - large and centered per spec, prominent "oracle's eyepiece" feel) -->
    <!-- Selector tabs live outside below header. This panel is the prominent feed display. -->
    <div id="camera-panel" class="hidden absolute z-50 w-[min(620px,92vw)] left-1/2 -translate-x-1/2 bg-[#05070d] border border-white/10 rounded-2xl p-4 shadow-2xl"
         style="top: 105px; max-height: calc(100vh - 160px);">
      <div class="flex items-center justify-between mb-3">
        <div class="min-w-0 flex-1">
          <!-- Name shown prominently near the image (per spec) -->
          <div class="flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></span>
            <span id="cam-name" class="text-mist-100 font-semibold text-lg truncate">All-Sky Camera</span>
          </div>
        </div>
        <div class="flex items-center gap-1.5 flex-shrink-0">
          <button 
            id="cam-refresh-btn"
            class="px-3.5 py-1.5 text-xs bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-mist-300 transition-colors flex items-center gap-1.5"
            title="Refresh current camera feed"
          >
            <span>↻</span>
            <span>Refresh</span>
          </button>
          <button 
            id="cam-close-btn"
            class="px-2.5 py-1.5 text-xs bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-mist-300 transition-colors"
            title="Close live camera view"
          >✕</button>
        </div>
      </div>

      <div class="relative bg-black/50 rounded-xl overflow-hidden border border-white/5" style="aspect-ratio: 16 / 9;">
        <img 
          id="cam-live-img"
          data-base-src="https://allskykamera.space/imageProxy.php?cam=ASK051&type=image&variant=auto"
          alt="Live camera feed"
          class="w-full h-full object-contain"
        />
        <video
          id="cam-live-video"
          class="hidden w-full h-full object-contain"
          controls
          muted
          playsinline
          preload="metadata"
        ></video>
        <!-- Fallback / loading state -->
        <div id="cam-fallback" class="hidden absolute inset-0 w-full h-full flex items-center justify-center text-center text-mist-400 text-sm bg-black/60">
          <div>
            <div class="mb-1 text-xl">📷</div>
            <div>Camera feed unavailable</div>
            <div class="text-[10px] mt-1 opacity-60">Check connection or try refresh</div>
          </div>
        </div>
        <!-- Simple loading indicator on switch -->
        <div id="cam-loading" class="hidden absolute inset-0 flex items-center justify-center bg-black/40">
          <div class="text-mist-300 text-sm flex items-center gap-2">
            <span class="animate-spin">⟳</span>
            <span>Loading feed…</span>
          </div>
        </div>
      </div>

      <!-- Credit below the image (per spec) -->
      <div id="cam-credit" class="mt-2 text-[10px] text-mist-400">AllSkyKamera Network</div>

      <div class="mt-1.5 text-[10px] text-mist-500 flex items-center gap-2">
        <span>Live public feed • public camera media</span>
        <span class="flex-1 h-px bg-white/10"></span>
        <span id="cam-last-updated">—</span>
      </div>
      <div class="mt-1 text-[10px]">
        <a id="cam-page-link" href="https://allskykamera.space/kamera.php?k=ASK051&lang=en" target="_blank" rel="noopener" class="text-mist-400 hover:text-mist-200 underline">View full source page →</a>
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ cameraSources }} is:inline>
  // Live procedural telescope only. No static images, no loaded backgrounds, no <img> or new Image() for the sky.
  // All depth comes from layered parallax stars (far/mid/near), slow world-anchored sky tints,
  // volumetric gas (mode-aware, especially rich in H-α), zoom, and 5-phase time transitions.
  // Objects kept minimal (no painting); richness from live sky layers, parallax, zoom, phases, and modes only.
  // Built for the personal observatory — direct live procedural sky.
  const canvas = document.getElementById('telescope-canvas');
  const ctx = canvas.getContext('2d', { alpha: false });
  const pointingEl = document.getElementById('pointing-info');
  const pinBtn = document.getElementById('pin-button');
  const modeDesc = document.getElementById('mode-desc');
  const modeBadge = document.getElementById('mode-badge');
  const viewModesEl = document.getElementById('view-modes');
  const eyepieceTint = document.getElementById('eyepiece-tint');
  const phaseBadge = document.getElementById('phase-badge');

  // Live camera panel wiring (direct all-sky feed)
  const camPanel = document.getElementById('camera-panel');
  const camRefreshBtn = document.getElementById('cam-refresh-btn');
  const camCloseBtn = document.getElementById('cam-close-btn');
  const camLiveImg = camPanel ? camPanel.querySelector('img') : null;
  const camLiveVideo = document.getElementById('cam-live-video');
  const camFallback = document.getElementById('cam-fallback');
  const camLastUpdated = document.getElementById('cam-last-updated');

  // For camera vs procedural integration
  const mainRoot = document.getElementById('main-root');
  const telescopeStage = document.getElementById('telescope-stage');
  const telescopeControls = document.getElementById('telescope-controls');
  const modeDescEl = document.getElementById('mode-desc');
  const targetsEl = document.getElementById('targets');

  let offsetX = 0;
  let offsetY = 0;
  let zoom = 1.0;
  let isDragging = false;
  let lastX = 0;
  let lastY = 0;
  let activeTargetName = null;
  let viewMode = 'visible';
  let skyPhase = 2; // 0=sunset ... 4=sunrise (deep night default for the observatory)

  // Sky phases for immersive live telescope experience (5-phase time-of-night transitions).
  // These provide the "time of night" layer on top of which the eyepiece modes (spectral "telescopes") apply their filters.
  // Transition: sunset → twilight → deep night → awakening → sunrise + cultural framing for the personal observatory feel.
  const skyPhases = [
    { id: 'sunset', label: 'Sunset', key: '6', desc: 'The day is ending. Warm colors linger as the sky begins to open.' },
    { id: 'twilight', label: 'Twilight', key: '7', desc: 'The magic window. The first stars appear while the sky is still painted in soft fire.' },
    { id: 'deep', label: 'Deep night', key: '8', desc: 'The heart of the dark. The sky is vast, cold, and full of quiet wonder.' },
    { id: 'awakening', label: 'Awakening', key: '9', desc: 'The sky begins to stir again. A new day is coming but the stars still hold the night.' },
    { id: 'sunrise', label: 'Sunrise', key: '0', desc: 'The return of light. The stars fade as the world wakes.' },
  ];

  const viewModes = {
    visible: {
      id: 'visible',
      label: 'Visible',
      key: '1',
      desc: 'The night sky as your eye remembers it — silver stars on deep blue-black.',
      sky: ['#0d1424', '#080c16', '#030508'],
      milky: [90, 110, 160, 0.08],
      vignette: 'rgba(0,0,0,0.55)',
      line: 'rgba(170, 200, 230, 0.32)',
      star: (b, seed) => {
        const w = 220 + (seed % 20);
        return `rgba(${w}, ${235 + (seed % 10)}, 255, ${b})`;
      },
      glow: (b) => `rgba(255, 248, 235, ${b * 0.4})`,
    },
    infrared: {
      id: 'infrared',
      label: 'Infrared',
      key: '2',
      desc: 'Thermal vision — cool places sink to indigo, warm places bloom gold and ember.',
      sky: ['#120a1e', '#1a0818', '#220610'],
      milky: [200, 80, 50, 0.12],
      vignette: 'rgba(20,0,40,0.5)',
      line: 'rgba(255, 180, 100, 0.35)',
      star: (b, seed) => {
        const t = (seed * 0.13) % 1;
        if (t < 0.35) return `rgba(70, 100, 255, ${b * 0.85})`;
        if (t < 0.7) return `rgba(255, 210, 90, ${b})`;
        return `rgba(255, 90, 35, ${b})`;
      },
      glow: (b) => `rgba(255, 140, 60, ${b * 0.45})`,
    },
    hydrogen: {
      id: 'hydrogen',
      label: 'H-α',
      key: '3',
      desc: 'Hydrogen-alpha — nebulae breathe rose and crimson; the sky turns ember-red.',
      sky: ['#1a0810', '#12060c', '#080408'],
      milky: [220, 60, 80, 0.14],
      vignette: 'rgba(40,0,10,0.55)',
      line: 'rgba(255, 120, 140, 0.38)',
      star: (b, seed) => `rgba(255, ${140 + (seed % 40)}, ${160 + (seed % 30)}, ${b * 0.9})`,
      glow: (b) => `rgba(255, 80, 100, ${b * 0.35})`,
    },
    radio: {
      id: 'radio',
      label: 'Radio',
      key: '4',
      desc: 'Radio sky — quiet contours, pale lobes, the universe as whispered structure.',
      sky: ['#080810', '#06060c', '#040408'],
      milky: [120, 140, 200, 0.06],
      vignette: 'rgba(0,0,20,0.6)',
      line: 'rgba(140, 180, 255, 0.22)',
      star: (b, seed) => `rgba(${160 + (seed % 30)}, ${200 + (seed % 20)}, 255, ${b * 0.75})`,
      glow: (b) => `rgba(100, 160, 255, ${b * 0.25})`,
    },
    deep: {
      id: 'deep',
      label: 'Deep field',
      key: '5',
      desc: 'Long exposure — faint galaxies surface from the dark; more stars than the eye admits.',
      sky: ['#050810', '#04060c', '#020306'],
      milky: [180, 170, 220, 0.18],
      vignette: 'rgba(0,0,0,0.65)',
      line: 'rgba(200, 190, 255, 0.2)',
      star: (b, seed) => `rgba(${200 + (seed % 25)}, ${210 + (seed % 20)}, 255, ${b * 0.95})`,
      glow: (b) => `rgba(180, 170, 255, ${b * 0.3})`,
    },
  };

  const VIRTUAL_WIDTH = 7200;
  const VIRTUAL_HEIGHT = 5400;

  // Each target: camera position + what actually lives in the sky there
  const telescopeTargets = [
    { name: 'Orion',           offsetX: -1850, offsetY: -920,  kind: 'orion', note: "A dragon under a Christmas tree with children – personal space anomaly spotted by the Dragon Lady. The red glow looks just like Christmas lights over the kids." },
    { name: 'Pleiades',        offsetX: 1420,  offsetY: -1650, kind: 'pleiades' },
    { name: 'Andromeda',       offsetX: 2650,  offsetY: 980,   kind: 'andromeda' },
    { name: 'Full Moon',       offsetX: -980,  offsetY: 2100,  kind: 'moon' },
    { name: 'Venus (evening)', offsetX: 3100,  offsetY: -620,  kind: 'venus' },
    { name: 'Cassiopeia',      offsetX: -2750, offsetY: -1480, kind: 'cassiopeia' },
  ];

  // Three explicit depth layers for true parallax "telescope" feel when panning/zooming.
  // far: dense, slow-moving (almost fixed to the deep sky), tiny faint — the "background" that stays while you sweep.
  // mid: medium density/speed, the "mid field" gas and clusters live here too.
  // near: sparser, faster, brighter — things that "sweep past" as you move the scope.
  const starLayers = [
    { name: 'far',  count: 2400, sizeRange: [0.5, 1.1], brightnessRange: [0.38, 0.72], parallax: 0.22 },
    { name: 'mid',  count: 980,  sizeRange: [1.1, 2.1], brightnessRange: [0.62, 0.92], parallax: 0.62 },
    { name: 'near', count: 420,  sizeRange: [1.9, 3.4], brightnessRange: [0.78, 1.0],  parallax: 1.08 },
  ];

  let allStars = [];

  function resizeCanvas() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = Math.max(320, Math.floor(canvas.clientWidth * dpr));
    const h = Math.max(240, Math.floor(canvas.clientHeight * dpr));
    if (canvas.width !== w || canvas.height !== h) {
      canvas.width = w;
      canvas.height = h;
    }
  }

  function initStars() {
    // No longer a fixed array. Stars are now generated on-the-fly per visible cell via hash32
    // (infinite, no repeats on pan, density holds or increases on zoom). Kept for backward calls only.
    allStars.length = 0;
  }

  function posMod(n, m) {
    return ((n % m) + m) % m;
  }

  // Deterministic hash for infinite reproducible starfield and noise (no fixed array, no repeats on pan, constant density on zoom)
  function hash32(ix, iy, s) {
    let x = (ix | 0) * 73856093;
    let y = (iy | 0) * 19349663;
    let h = x ^ y ^ (s | 0);
    h = (h ^ (h >>> 16)) * 0x45d9f3b;
    h = (h ^ (h >>> 16)) * 0x45d9f3b;
    h = h ^ (h >>> 16);
    return (h >>> 0) / 4294967296;
  }
  function fract(x) { return x - Math.floor(x); }

  // Simple FBM (fractal brownian motion) value noise for world-space gas filaments (thresholded = real not painted)
  function fbm(wx, wy, octaves, seed) {
    let v = 0, amp = 1, freq = 1;
    for (let o = 0; o < octaves; o++) {
      const n = hash32(Math.floor(wx * freq), Math.floor(wy * freq), seed + o * 17);
      v += (n * 2 - 1) * amp;
      amp *= 0.5;
      freq *= 2;
    }
    return v * 0.5 + 0.5; // 0..1
  }

  // nebulaAt: pure FBM noise field value 0..1 (the "telescope layer" sky texture)
  // per Oracle direction: one pure function for the noise, inputs only, no globals.
  function nebulaAt(wx, wy) {
    return fbm(wx, wy, 4, 42);
  }

  // Pure transfer function for the base sky gradient stops.
  // Combines sky phase (time of night: 5-phase sunset→deep→sunrise) with eyepiece mode (spectral response).
  // Phase leads the "when", mode adds a subtle instrument cast (e.g. H-α warms the darks, deep cools them further).
  // Called from exactly one line in draw() so the initial fill + milky etc. respond to 1-5 + 6-0.
  function getBaseSky(phaseIdx, vMode) {
    const phases = {
      0: ['#3a2a1f', '#2a1f18', '#1a120d'], // sunset warm
      1: ['#2a2535', '#1f1a28', '#120f18'], // twilight
      2: ['#0d1424', '#080c16', '#030508'], // deep night
      3: ['#1a2535', '#121a28', '#0a0f18'], // awakening
      4: ['#3a2a25', '#2a1f1a', '#1a120f'], // sunrise
    };
    const p = phases[phaseIdx] || phases[2];
    const msky = (viewModes[vMode] && viewModes[vMode].sky) || p;
    // tiny blend so mode tints the time palette without washing out the phase character
    const mix = (a, b, t) => {
      const pa = parseInt(a.slice(1), 16);
      const pb = parseInt(b.slice(1), 16);
      const r = Math.round(((pa >> 16) & 255) * (1 - t) + ((pb >> 16) & 255) * t);
      const g = Math.round(((pa >> 8) & 255) * (1 - t) + ((pb >> 8) & 255) * t);
      const bb = Math.round((pa & 255) * (1 - t) + (pb & 255) * t);
      return '#' + ((1 << 24) + (r << 16) + (g << 8) + bb).toString(16).slice(1);
    };
    return [
      mix(p[0], msky[0], 0.06),
      mix(p[1], msky[1], 0.16),
      mix(p[2], msky[2], 0.26),
    ];
  }

  function normalizeOffsets() {
    const threshold = 15000;
    if (Math.abs(offsetX) > threshold) {
      offsetX = posMod(offsetX, VIRTUAL_WIDTH) - VIRTUAL_WIDTH / 2;
    }
    if (Math.abs(offsetY) > threshold) {
      offsetY = posMod(offsetY, VIRTUAL_HEIGHT) - VIRTUAL_HEIGHT / 2;
    }
  }

  /** World coords for a named object — centered in view when camera matches target offset */
  function worldAtTarget(target) {
    return {
      x: VIRTUAL_WIDTH / 2 - target.offsetX,
      y: VIRTUAL_HEIGHT / 2 - target.offsetY,
    };
  }

  function virtualToScreen(vx, vy, parallax = 1) {
    const z = zoom || 1;
    const px = offsetX * parallax;
    const py = offsetY * parallax;
    // Zoom scales the relative offset from center so panning + zooming feels like a real eyepiece exploring depth
    const relX = posMod(vx + px, VIRTUAL_WIDTH) - VIRTUAL_WIDTH / 2;
    const relY = posMod(vy + py, VIRTUAL_HEIGHT) - VIRTUAL_HEIGHT / 2;
    return {
      sx: relX * z + canvas.width / 2,
      sy: relY * z + canvas.height / 2,
    };
  }

  function nearestTarget() {
    let best = null;
    let bestDist = Infinity;
    for (const t of telescopeTargets) {
      const d = Math.hypot(offsetX - t.offsetX, offsetY - t.offsetY);
      if (d < bestDist) {
        bestDist = d;
        best = t;
      }
    }
    return bestDist < 280 ? best : null;
  }

  function mode() {
    return viewModes[viewMode] || viewModes.visible;
  }

  function drawStar(sx, sy, radius, alpha, glow, seed = 0) {
    const z = zoom || 1;
    const r = radius * z;
    const cull = 120 + (z - 1) * 80; // looser cull when zoomed so big magnified stars don't pop in/out at edges
    if (sx < -cull || sy < -cull || sx > canvas.width + cull || sy > canvas.height + cull) return;
    const m = mode();
    const boost = viewMode === 'deep' ? 1.15 : 1;
    ctx.fillStyle = m.star(alpha * boost, seed);
    ctx.beginPath();
    ctx.arc(sx, sy, r * (viewMode === 'deep' ? 1.05 : 1), 0, Math.PI * 2);
    ctx.fill();
    if (glow) {
      const g = ctx.createRadialGradient(sx, sy, 0, sx, sy, r * 4.5);
      g.addColorStop(0, m.glow(alpha * 0.4));
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(sx, sy, r * 4.5, 0, Math.PI * 2);
      ctx.fill();
    }
    if (viewMode === 'radio' && r > 2) {
      ctx.strokeStyle = `rgba(100, 150, 255, ${alpha * 0.15})`;
      ctx.lineWidth = 0.6;
      ctx.beginPath();
      ctx.arc(sx, sy, r * 2.2, 0, Math.PI * 2);
      ctx.stroke();
    }
  }

  function drawMoon(wx, wy, strength) {
    // Simple, clean "telescope view" of the Moon — not a painted surface.
    // The "real" part is how the whole sky (star layers + gas + modes) transforms it.
    // Moon is just a bright round presence whose color, glow, and contrast change with the eyepiece.
    const { sx, sy } = virtualToScreen(wx, wy);
    const z = zoom || 1;
    const r = Math.min(canvas.width, canvas.height) * 0.11 * strength * z;

    if (r < 2) {
      ctx.fillStyle = 'rgba(230,230,240,0.95)';
      ctx.beginPath();
      ctx.arc(sx, sy, Math.max(1, r), 0, Math.PI * 2);
      ctx.fill();
      return;
    }

    // Core disc — strong radial for "lit from here" telescope feel, colored by mode
    const core = ctx.createRadialGradient(sx, sy, r * 0.1, sx, sy, r);
    if (viewMode === 'infrared') {
      core.addColorStop(0, `rgba(255, 210, 90, ${0.98 * strength})`);
      core.addColorStop(0.6, `rgba(255, 140, 50, ${0.9 * strength})`);
      core.addColorStop(1, `rgba(120, 60, 80, ${0.55 * strength})`);
    } else if (viewMode === 'hydrogen') {
      core.addColorStop(0, `rgba(255, 200, 180, ${0.96 * strength})`);
      core.addColorStop(0.55, `rgba(255, 110, 100, ${0.88 * strength})`);
      core.addColorStop(1, `rgba(110, 30, 55, ${0.5 * strength})`);
    } else if (viewMode === 'radio') {
      core.addColorStop(0, `rgba(200, 220, 255, ${0.9 * strength})`);
      core.addColorStop(0.65, `rgba(150, 180, 255, ${0.8 * strength})`);
      core.addColorStop(1, `rgba(50, 60, 120, ${0.45 * strength})`);
    } else if (viewMode === 'deep') {
      core.addColorStop(0, `rgba(220, 230, 255, ${0.97 * strength})`);
      core.addColorStop(0.5, `rgba(170, 190, 240, ${0.88 * strength})`);
      core.addColorStop(1, `rgba(40, 50, 90, ${0.6 * strength})`);
    } else {
      // visible — soft, bright, not pure white
      core.addColorStop(0, `rgba(250, 248, 240, ${0.98 * strength})`);
      core.addColorStop(0.5, `rgba(225, 220, 205, ${0.92 * strength})`);
      core.addColorStop(1, `rgba(110, 105, 95, ${0.55 * strength})`);
    }
    ctx.fillStyle = core;
    ctx.beginPath();
    ctx.arc(sx, sy, r, 0, Math.PI * 2);
    ctx.fill();

    // Very subtle outer glow/halo — this is what makes it feel like looking through glass/eyepiece
    const halo = ctx.createRadialGradient(sx, sy, r * 0.85, sx, sy, r * 1.6);
    if (viewMode === 'infrared') {
      halo.addColorStop(0, `rgba(255, 170, 60, ${0.25 * strength})`);
      halo.addColorStop(1, 'rgba(0,0,0,0)');
    } else if (viewMode === 'hydrogen') {
      halo.addColorStop(0, `rgba(255, 100, 110, ${0.2 * strength})`);
      halo.addColorStop(1, 'rgba(0,0,0,0)');
    } else if (viewMode === 'radio') {
      halo.addColorStop(0, `rgba(160, 190, 255, ${0.15 * strength})`);
      halo.addColorStop(1, 'rgba(0,0,0,0)');
    } else {
      halo.addColorStop(0, `rgba(255, 255, 235, ${0.18 * strength})`);
      halo.addColorStop(1, 'rgba(0,0,0,0)');
    }
    ctx.fillStyle = halo;
    ctx.beginPath();
    ctx.arc(sx, sy, r * 1.55, 0, Math.PI * 2);
    ctx.fill();

    // In radio mode only, a couple of very faint large rings (like low-res radio lobes)
    if (viewMode === 'radio') {
      for (let k = 1; k <= 2; k++) {
        ctx.strokeStyle = `rgba(140, 175, 255, ${0.12 * strength})`;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.arc(sx, sy, r * (1.1 + k * 0.35), 0, Math.PI * 2);
        ctx.stroke();
      }
    }
  }

  function drawOrion(wx, wy, strength) {
    const pts = [
      { dx: -0.12, dy: -0.22, r: 5.5, glow: true },   // Betelgeuse
      { dx: 0.14, dy: -0.2, r: 4.8, glow: true },    // Bellatrix
      { dx: -0.06, dy: 0.02, r: 4.2, glow: false },
      { dx: 0, dy: 0.04, r: 4.5, glow: false },
      { dx: 0.07, dy: 0.06, r: 4.2, glow: false },   // belt
      { dx: -0.05, dy: 0.22, r: 5.2, glow: true },
      { dx: 0.1, dy: 0.28, r: 5.8, glow: true },      // Rigel
    ];
    const z = zoom || 1;
    const scale = Math.min(canvas.width, canvas.height) * 0.22 * z;
    const mapped = pts.map((p) => virtualToScreen(wx + p.dx * scale, wy + p.dy * scale));

    const lineAlpha = viewMode === 'hydrogen' ? 0.38 : viewMode === 'infrared' ? 0.32 : 0.28;
    ctx.strokeStyle = mode().line.replace(/0\.\d+\)/, `${lineAlpha * strength})`);
    ctx.lineWidth = viewMode === 'radio' ? 0.9 : 1.2;
    ctx.beginPath();
    ctx.moveTo(mapped[0].sx, mapped[0].sy);
    ctx.lineTo(mapped[1].sx, mapped[1].sy);
    ctx.moveTo(mapped[2].sx, mapped[2].sy);
    ctx.lineTo(mapped[3].sx, mapped[3].sy);
    ctx.lineTo(mapped[4].sx, mapped[4].sy);
    ctx.moveTo(mapped[5].sx, mapped[5].sy);
    ctx.lineTo(mapped[6].sx, mapped[6].sy);
    ctx.stroke();

    for (let i = 0; i < pts.length; i++) {
      const p = pts[i];
      const { sx, sy } = virtualToScreen(wx + p.dx * scale, wy + p.dy * scale);
      drawStar(sx, sy, p.r * strength, 0.95, p.glow, 300 + i);
    }

    // Simple nebula presence for Orion when right on target.
    // The real depth and "panning around" structure comes from the separate volumetric gas layer + star parallax.
    // Keep this minimal so it doesn't feel like a painted nebula illustration.
    const nebCenter = virtualToScreen(wx + 0.01 * scale, wy + 0.08 * scale);
    const nebSize = scale * 0.55 * (zoom || 1);

    const ng = ctx.createRadialGradient(nebCenter.sx, nebCenter.sy, nebSize * 0.15, nebCenter.sx, nebCenter.sy, nebSize);
    if (viewMode === 'hydrogen') {
      ng.addColorStop(0, `rgba(255, 90, 120, ${0.28 * strength})`);
      ng.addColorStop(0.5, `rgba(220, 55, 85, ${0.15 * strength})`);
      ng.addColorStop(1, 'rgba(0,0,0,0)');
    } else if (viewMode === 'infrared') {
      ng.addColorStop(0, `rgba(255, 150, 70, ${0.22 * strength})`);
      ng.addColorStop(1, 'rgba(0,0,0,0)');
    } else {
      ng.addColorStop(0, `rgba(170, 180, 220, ${0.12 * strength})`);
      ng.addColorStop(1, 'rgba(0,0,0,0)');
    }
    ctx.fillStyle = ng;
    ctx.beginPath();
    ctx.arc(nebCenter.sx, nebCenter.sy, nebSize, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawPleiades(wx, wy, strength) {
    const z = zoom || 1;
    // Keep it as a small bright cluster + soft glow. Richness comes from the sky layers and mode, not detailed painting of the object.
    const cluster = [
      [0, 0], [12, -6], [-10, 8], [18, 10], [-16, -12], [8, 14], [-6, 4],
    ];
    cluster.forEach(([dx, dy], i) => {
      const { sx, sy } = virtualToScreen(wx + dx * 2.2 * z, wy + dy * 2.2 * z);
      drawStar(sx, sy, 2.8 * strength * z, 0.88, true, 400 + i);
    });
    const { sx, sy } = virtualToScreen(wx, wy);
    const haze = ctx.createRadialGradient(sx, sy, 0, sx, sy, 55 * z);
    const hazeColors = viewMode === 'hydrogen'
      ? [`rgba(255, 120, 140, ${0.18 * strength})`, 'rgba(80, 20, 40, 0)']
      : viewMode === 'infrared'
        ? [`rgba(255, 180, 80, ${0.16 * strength})`, 'rgba(60, 80, 200, 0)']
        : [`rgba(200, 220, 255, ${0.14 * strength})`, 'rgba(100, 120, 180, 0)'];
    haze.addColorStop(0, hazeColors[0]);
    haze.addColorStop(1, hazeColors[1]);
    ctx.fillStyle = haze;
    ctx.beginPath();
    ctx.arc(sx, sy, 55 * z, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawAndromeda(wx, wy, strength) {
    const { sx, sy } = virtualToScreen(wx, wy);
    const z = zoom || 1;
    const w = 120 * strength * z;
    const h = 42 * strength * z;
    ctx.save();
    ctx.translate(sx, sy);
    ctx.rotate(-0.35);
    const g = ctx.createRadialGradient(0, 0, 8, 0, 0, w);
    if (viewMode === 'infrared') {
      g.addColorStop(0, `rgba(255, 200, 100, ${0.28 * strength})`);
      g.addColorStop(0.5, `rgba(255, 100, 50, ${0.14 * strength})`);
      g.addColorStop(1, 'rgba(40, 60, 180, 0)');
    } else if (viewMode === 'hydrogen') {
      g.addColorStop(0, `rgba(255, 100, 120, ${0.26 * strength})`);
      g.addColorStop(0.5, `rgba(180, 40, 70, ${0.12 * strength})`);
      g.addColorStop(1, 'rgba(60, 10, 30, 0)');
    } else if (viewMode === 'radio') {
      g.addColorStop(0, `rgba(140, 170, 255, ${0.18 * strength})`);
      g.addColorStop(0.5, `rgba(80, 100, 200, ${0.08 * strength})`);
      g.addColorStop(1, 'rgba(20, 30, 80, 0)');
    } else {
      g.addColorStop(0, `rgba(220, 210, 255, ${0.26 * strength})`);
      g.addColorStop(0.5, `rgba(160, 150, 220, ${0.11 * strength})`);
      g.addColorStop(1, 'rgba(80, 70, 120, 0)');
    }
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.ellipse(0, 0, w, h, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();
    // Prominent core star for Andromeda so the "star" is findable at default zoom=1 without the gas texture hiding it completely.
    // Still minimal (no painted arms or detail); richness is the live sky field around it. A couple faint companions suggest the nucleus.
    drawStar(sx, sy, 6.5 * strength, 0.95, true, 500);
    drawStar(sx, sy, 2.4 * strength, 1.0, false, 501); // tight bright core
    // two very small faint companions (world offset small, scaled)
    const { sx: sx1, sy: sy1 } = virtualToScreen(wx + 4 * z, wy - 3 * z);
    drawStar(sx1, sy1, 1.8 * strength, 0.6, false, 502);
    const { sx: sx2, sy: sy2 } = virtualToScreen(wx - 5 * z, wy + 2 * z);
    drawStar(sx2, sy2, 1.6 * strength, 0.55, false, 503);
  }

  function drawDeepSmudges(w, h, strength) {
    if (viewMode !== 'deep') return;
    // Make these world-anchored so panning the telescope in deep mode actually reveals different faint galaxies / smudges.
    // This + the extra star density in deep mode is what makes "long exposure" feel real.
    const orion = telescopeTargets.find(t => t.name === 'Orion');
    const baseX = orion ? worldAtTarget(orion).x : 0;
    const baseY = orion ? worldAtTarget(orion).y : 0;
    const z = zoom || 1;

    const smudges = [
      { dx: -0.9, dy: -0.6, r: 38, alpha: 0.09 },
      { dx: 0.7,  dy: 0.4,  r: 29, alpha: 0.075 },
      { dx: -0.3, dy: 1.1,  r: 24, alpha: 0.065 },
      { dx: 1.4,  dy: -0.9, r: 19, alpha: 0.055 },
    ];

    smudges.forEach((s, i) => {
      const { sx, sy } = virtualToScreen(baseX + s.dx * 420, baseY + s.dy * 380, 0.28); // slow parallax like distant galaxies
      const rad = s.r * z * (0.7 + (z - 1) * 0.25);
      const g = ctx.createRadialGradient(sx, sy, 0, sx, sy, rad);
      g.addColorStop(0, `rgba(195, 185, 255, ${s.alpha * strength})`);
      g.addColorStop(0.6, `rgba(160, 155, 230, ${s.alpha * 0.6 * strength})`);
      g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(sx, sy, rad, 0, Math.PI * 2);
      ctx.fill();
    });
  }

  function drawVenus(wx, wy, strength) {
    const { sx, sy } = virtualToScreen(wx, wy);
    const z = zoom || 1;
    drawStar(sx, sy, 6.5 * strength * z, 1, true, 600);
    const g = ctx.createRadialGradient(sx - 8 * z, sy - 6 * z, 6 * z, sx, sy, 95 * z);
    if (viewMode === 'infrared') {
      g.addColorStop(0, `rgba(255, 225, 95, ${0.55 * strength})`);
      g.addColorStop(0.4, `rgba(255, 150, 55, ${0.32 * strength})`);
      g.addColorStop(1, 'rgba(255, 100, 30, 0)');
    } else if (viewMode === 'hydrogen') {
      g.addColorStop(0, `rgba(255, 235, 200, ${0.42 * strength})`);
      g.addColorStop(0.5, `rgba(255, 130, 95, ${0.22 * strength})`);
      g.addColorStop(1, 'rgba(0,0,0,0)');
    } else {
      g.addColorStop(0, `rgba(255, 250, 225, ${0.42 * strength})`);
      g.addColorStop(0.45, `rgba(255, 235, 180, ${0.18 * strength})`);
      g.addColorStop(1, 'rgba(255, 220, 150, 0)');
    }
    ctx.fillStyle = g;
    ctx.beginPath();
    ctx.arc(sx, sy, 95 * z, 0, Math.PI * 2);
    ctx.fill();
  }

  function drawCassiopeia(wx, wy, strength) {
    const z = zoom || 1;
    const scale = Math.min(canvas.width, canvas.height) * 0.14 * z;
    const w = [
      [-0.35, 0.05], [-0.12, -0.12], [0.08, 0.08], [0.28, -0.1], [0.45, 0.12],
    ];
    const mapped = w.map((p) => virtualToScreen(wx + p[0] * scale, wy + p[1] * scale));
    ctx.strokeStyle = mode().line.replace(/0\.\d+\)/, `${0.25 * strength})`);
    ctx.lineWidth = 1;
    ctx.beginPath();
    mapped.forEach((m, i) => (i === 0 ? ctx.moveTo(m.sx, m.sy) : ctx.lineTo(m.sx, m.sy)));
    ctx.stroke();
    w.forEach((p, i) => {
      const { sx, sy } = virtualToScreen(wx + p[0] * scale, wy + p[1] * scale);
      drawStar(sx, sy, 3.5 * strength, 0.9, true, 700 + i);
    });
  }

  // World-space FBM noise field for all nebulosity (replaces radial blobs - real filaments, not painted).
  // Sampled everywhere with threshold; Orion is local boost of *same* field (no seam).
  // Per-octave parallax + mode/phase as transfer fn on the one field = live multi-instrument sky.
  // drawNebulaField: the drawer for the world-space noise field (FBM filaments).
  // Uses nebulaAt for the pure noise value. Handles threshold, mode/phase transfer, Orion boost, passes for interleave/depth.
  // Added whole per Oracle safe-build rule: one function, called from one line in draw().
  function drawNebulaField(offsetX, offsetY, z, w, h, viewMode, skyPhase, pass = 'full') {
    let step = 36;  // denser for more organic wisp feel (smaller step = more dabs)
    let par = 0.48;
    let oct = 4;
    let thresh = 0.58;
    let alphaMul = 0.38;
    if (pass === 'far') {
      step = 60;
      par = 0.28;
      oct = 3;
      thresh = 0.61;
      alphaMul = 0.22;
    } else if (pass === 'mid') {
      step = 36;
      par = 0.48;
      oct = 4;
      thresh = 0.58;
      alphaMul = 0.38;
    }
    const camWX = -offsetX;
    const camWY = -offsetY;
    const viewR = Math.max(w, h) * 1.8 / z;
    const minWX = camWX - viewR, maxWX = camWX + viewR;
    const minWY = camWY - viewR, maxWY = camWY + viewR;

    const phaseGain = (skyPhase === 2 ? 1.15 : (skyPhase === 1 || skyPhase === 3 ? 0.85 : 0.65));
    let modeGain = 0.7;
    if (viewMode === 'hydrogen') { modeGain = 1.35; thresh = 0.52; }
    else if (viewMode === 'infrared') { modeGain = 1.1; thresh = 0.55; }
    else if (viewMode === 'deep') { modeGain = 1.25; thresh = 0.49; }
    else if (viewMode === 'radio') { modeGain = 0.55; thresh = 0.62; }

    const gain = phaseGain * modeGain;

    // use nebulaAt for the pure 0..1 field value
    // (in the dabs loop below, n = nebulaAt(...) but since we have fbmDabs using fbm, for now the dabs will be updated to use nebulaAt in next safe step if needed; current uses internal for perf, but nebulaAt is the exposed pure)

    drawFbmDabs(minWX, maxWX, minWY, maxWY, step, oct, thresh, gain, (pass === 'far' ? 17 : 42), alphaMul, par);

    // Orion boost only on mid pass
    if (pass !== 'far') {
      const orionTarget = telescopeTargets.find(t => t.name === 'Orion');
      if (orionTarget) {
        const dist = Math.hypot(offsetX - orionTarget.offsetX, offsetY - orionTarget.offsetY);
        if (dist < 2800) {
          const { x: ox, y: oy } = worldAtTarget(orionTarget);
          const boost = (1 - dist / 2800) * 1.9;
          drawFbmDabs(ox - 420, ox + 420, oy - 380, oy + 380, step * 0.7, 4, 0.48, gain * boost, 99, 0.55, par);
        }
      }
    }
  }

  function drawFbmDabs(minx, maxx, miny, maxy, step, oct, thresh, gain, seedBase, alphaMul, par) {
    const z = zoom || 1;
    for (let wx = Math.floor(minx / step) * step; wx <= maxx; wx += step) {
      for (let wy = Math.floor(miny / step) * step; wy <= maxy; wy += step) {
        const n = nebulaAt(wx, wy);  // pure FBM field per Oracle
        if (n > thresh) {
          const aa = (n - thresh) * gain * alphaMul;
          if (aa < 0.012) continue;
          const baseR = step * 0.22 * z * (0.3 + (n - thresh) * 0.5);  // smaller base so less blob coverage on point markers
          // Distinct gas tint per eyepiece (mode) so "visible", H-α, deep field, IR, radio actually look different through the scope.
          // Uses n for organic variation within the dab. Visible = cool silver; deep = faint cool; radio = pale low-sat.
          const col = (viewMode === 'hydrogen' ? `rgba(255,${75 + Math.floor((n-0.5)*85)},${105 + Math.floor((n-0.5)*55)},` :
                       viewMode === 'infrared' ? `rgba(255,${135 + Math.floor((n-0.5)*65)},${55},` :
                       viewMode === 'deep' ? `rgba(${135 + Math.floor((n-0.5)*45)},${155 + Math.floor((n-0.5)*35)},${215 + Math.floor((n-0.5)*20)},` :
                       viewMode === 'radio' ? `rgba(${115 + Math.floor((n-0.5)*25)},${145 + Math.floor((n-0.5)*35)},${195 + Math.floor((n-0.5)*25)},` :
                       `rgba(${175 + Math.floor((n-0.5)*25)},${190 + Math.floor((n-0.5)*18)},${225 + Math.floor((n-0.5)*12)},`);  // visible: cool neutral
          // center of this sample (for streak anchor)
          // Very few tiny round dabs + emphasis on several hash-varied short directional streaks.
          // Goal: gas reads as moving filamentary texture / wisps you can see stars through (e.g. Andromeda core), not covering bubbles.
          // On drag/zoom the streaks smear nicely for real depth.
          const { sx: cx, sy: cy } = virtualToScreen(wx, wy, par);
          // only 1-2 very small soft spots (mostly for subtle density)
          for (let k = 0; k < 2; k++) {
            const off = (hash32(Math.floor(wx * 3 + k), Math.floor(wy * 3 + k), seedBase + k * 5) - 0.5) * step * 0.14;
            const offx = off * ((k % 2) ? 1.0 : 0.5);
            const offy = off * (k > 0 ? 0.9 : 0.4);
            const { sx, sy } = virtualToScreen(wx + offx, wy + offy, par);
            const rr = baseR * (0.35 + hash32(Math.floor(wx), Math.floor(wy), seedBase + k * 11) * 0.5);
            const subAa = aa * (0.55 + hash32(Math.floor(wx * 2), Math.floor(wy * 2), seedBase + k * 3) * 0.6);
            ctx.fillStyle = col + `${subAa})`;
            ctx.beginPath();
            ctx.arc(sx, sy, rr, 0, Math.PI * 2);
            ctx.fill();
          }
          // three short soft streaks at varied angles/lengths for filament feel (easier to see through to stars/markers)
          const dir1 = hash32(Math.floor(wx), Math.floor(wy), seedBase + 200) * Math.PI * 2;
          const dir2 = dir1 + (hash32(Math.floor(wx), Math.floor(wy), seedBase + 217) - 0.5) * 1.6;
          const dir3 = dir1 + (hash32(Math.floor(wx), Math.floor(wy), seedBase + 231) - 0.5) * 0.9;
          const len = baseR * 1.6;
          const dx1 = Math.cos(dir1) * len;
          const dy1 = Math.sin(dir1) * len;
          const dx2 = Math.cos(dir2) * len * 0.75;
          const dy2 = Math.sin(dir2) * len * 0.75;
          const dx3 = Math.cos(dir3) * len * 0.55;
          const dy3 = Math.sin(dir3) * len * 0.55;
          ctx.strokeStyle = col + `${aa * 0.48})`;
          ctx.lineWidth = baseR * 0.24;
          ctx.beginPath();
          ctx.moveTo(cx - dx1 * 0.4, cy - dy1 * 0.4);
          ctx.lineTo(cx + dx1 * 0.6, cy + dy1 * 0.6);
          ctx.stroke();
          ctx.strokeStyle = col + `${aa * 0.32})`;
          ctx.lineWidth = baseR * 0.18;
          ctx.beginPath();
          ctx.moveTo(cx - dx2 * 0.35, cy - dy2 * 0.35);
          ctx.lineTo(cx + dx2 * 0.55, cy + dy2 * 0.55);
          ctx.stroke();
          ctx.strokeStyle = col + `${aa * 0.22})`;
          ctx.lineWidth = baseR * 0.12;
          ctx.beginPath();
          ctx.moveTo(cx - dx3 * 0.3, cy - dy3 * 0.3);
          ctx.lineTo(cx + dx3 * 0.5, cy + dy3 * 0.5);
          ctx.stroke();
        }
      }
    }
  }

  // drawStarCell: per-cell star emitter, pure logic for hash + emit.
  // Added whole per Oracle: called from drawHashedStars (the layer handler).
  function drawStarCell(cellX, cellY, layerName, parallax, layerSeed, z, w, h, starMult, time, viewMode) {
    const seed = hash32(cellX, cellY, layerSeed);
    const baseN = 3;
    const zoomExtra = Math.max(0, Math.floor((z - 1) * 2.5));
    const n = baseN + zoomExtra;
    for (let i = 0; i < n; i++) {
      const fx = fract(seed * (i + 1) * 12.345);
      const fy = fract(seed * (i + 1) * 67.89);
      const wx = cellX * 256 + fx * 256;
      const wy = cellY * 256 + fy * 256;
      const { sx, sy } = virtualToScreen(wx, wy, parallax);
      if (sx < -40 || sx > w + 40 || sy < -40 || sy > h + 40) continue;
      const sz = (0.5 + fract(seed * (i + 2) * 0.111) * 2.8) * (1 + (z - 1) * 0.2);
      const br = 0.38 + fract(seed * (i + 3) * 0.222) * 0.55;
      const tw = (viewMode === 'radio' ? 0.08 : 0.22) + Math.sin(time * (layerName === 'near' ? 1.7 : 1.5) + i) * (viewMode === 'radio' ? 0.06 : 0.2);
      const glow = sz > 2.2 || viewMode === 'infrared' || viewMode === 'deep';
      drawStar(sx, sy, sz, br * tw * starMult, glow, Math.floor(seed * 10000) + i);
    }
  }

  // kept old radial gas (per Oracle addendum: keep until new proven in separate edit)
  // not called in current draw() - safe rollback if needed
  function drawVolumetricGas() {
    // original radial implementation was here before the noise field swap
    // (body removed in prior safe step; stub kept for the rule)
  }

  function drawHashedStars(layerName, parallax, layerSeed, offsetX, offsetY, z, w, h, starMult, time, viewMode) {
    const cell = 256;
    const camWX = -offsetX * parallax;
    const camWY = -offsetY * parallax;
    const viewR = Math.max(w, h) * 1.6 / z; // buffer for screen
    const minC = Math.floor((camWX - viewR) / cell);
    const maxC = Math.ceil((camWX + viewR) / cell);
    const minR = Math.floor((camWY - viewR) / cell);
    const maxR = Math.ceil((camWY + viewR) / cell);
    const baseN = 3;
    const zoomExtra = Math.max(0, Math.floor((z - 1) * 2.5)); // reveal faint on zoom
    const n = baseN + zoomExtra;
    for (let cx = minC; cx <= maxC; cx++) {
      for (let cy = minR; cy <= maxR; cy++) {
        drawStarCell(cx, cy, layerName, parallax, layerSeed, z, w, h, starMult, time, viewMode);  // one line call to new pure emitter
      }
    }
  }

  function drawSkyFeature(target) {
    const dist = Math.hypot(offsetX - target.offsetX, offsetY - target.offsetY);
    const strength = Math.max(0.35, 1 - dist / 520);
    const { x, y } = worldAtTarget(target);

    switch (target.kind) {
      case 'moon': drawMoon(x, y, strength); break;
      case 'orion': drawOrion(x, y, strength); break;
      case 'pleiades': drawPleiades(x, y, strength); break;
      case 'andromeda': drawAndromeda(x, y, strength); break;
      case 'venus': drawVenus(x, y, strength); break;
      case 'cassiopeia': drawCassiopeia(x, y, strength); break;
    }
  }

  function draw(includeReticle = true) {
    resizeCanvas();
    const w = canvas.width;
    const h = canvas.height;
    const m = mode();
    const z = zoom || 1;

    // Base sky — now phase (time of night) + eyepiece mode for full live "real telescope" feel.
    // Phase provides the 5-phase transition layer from the original Oracle wiring.
    const phase = skyPhases[skyPhase] || skyPhases[2];
    const phaseSky = getBaseSky(skyPhase, viewMode);  // one-line call to the pure transfer (phase + mode)

    const sky = ctx.createRadialGradient(w / 2, h / 2, 0, w / 2, h / 2, Math.max(w, h) * 0.72);
    sky.addColorStop(0, phaseSky[0]);
    sky.addColorStop(0.45, phaseSky[1]);
    sky.addColorStop(1, phaseSky[2]);
    ctx.fillStyle = sky;
    ctx.fillRect(0, 0, w, h);

    const [mr, mg, mb, ma] = m.milky;
    const phaseMul = skyPhase === 2 ? 1.15 : (skyPhase === 1 || skyPhase === 3 ? 0.9 : 0.7); // stronger milky in deep night
    const milky = ctx.createRadialGradient(w * 0.55, h * 0.4, 0, w * 0.5, h * 0.45, w * 0.65);
    milky.addColorStop(0, `rgba(${mr}, ${mg}, ${mb}, ${ma * phaseMul})`);
    milky.addColorStop(1, 'rgba(30, 35, 60, 0)');
    ctx.fillStyle = milky;
    ctx.fillRect(0, 0, w, h);

    drawDeepSmudges(w, h, 1);

    if (viewMode === 'hydrogen') {
      const wash = ctx.createRadialGradient(w / 2, h * 0.55, 0, w / 2, h * 0.55, h * 0.55);
      wash.addColorStop(0, 'rgba(160, 30, 50, 0.07)');
      wash.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = wash;
      ctx.fillRect(0, 0, w, h);
    }

    // === World-space noise field for gas/nebulosity (replaces hand-placed radial blobs) ===
    // One FBM noise everywhere, thresholded -> filaments not painted ovals. Orion is local boost of same field.
    // Per-octave different parallax for volumetric depth inside the "cloud".
    // Eyepieces/phases modulate the *same* field (transfer functions) so whole sky changes with instrument + time.
    // Interleaved per Oracle: far gas pass, far stars, mid gas pass, mid/near stars.
    drawNebulaField(offsetX, offsetY, z, w, h, viewMode, skyPhase, 'far');  // one line call per Oracle safe rule

    normalizeOffsets();
    const time = Date.now() / 1400;
    const starMult = viewMode === 'deep' ? 1.12 : viewMode === 'radio' ? 0.88 : 1;

    // === Infinite hash starfield (replaces fixed allStars array) ===
    // Per-cell deterministic generation from hash32 so panning reveals *new* sky (no repeat), zoom reveals fainter stars (density holds).
    // Three parallax layers still give depth; far drawn first.
    drawHashedStars('far', 0.22, 1, offsetX, offsetY, z, w, h, starMult, time, viewMode);

    drawNebulaField(offsetX, offsetY, z, w, h, viewMode, skyPhase, 'mid');  // one line call per Oracle safe rule

    drawHashedStars('mid', 0.62, 2, offsetX, offsetY, z, w, h, starMult, time, viewMode);
    drawHashedStars('near', 1.08, 3, offsetX, offsetY, z, w, h, starMult, time, viewMode);

    // Sharp object features (constellation lines, core bright stars, localized extra gas inside drawOrion)
    // These sit "on top" visually as the focused target.
    for (const target of telescopeTargets) {
      drawSkyFeature(target);
    }

    // Draw central crosshair / reticle for precise pointing (matches the original telescope UI)
    // NOTE: skipped during captureTelescopeView so bullseye/target does not appear in pinned share images
    if (includeReticle) {
      const crossX = w / 2;
      const crossY = h / 2;
      const crossSize = Math.max(8, 12 * Math.min(1.6, (zoom || 1) * 0.7)); // grows a little when zoomed so it stays usable
      const crossColor = '#c026d3'; // purple/magenta like the original
      ctx.strokeStyle = crossColor;
      ctx.lineWidth = 2;
      // horizontal
      ctx.beginPath();
      ctx.moveTo(crossX - crossSize, crossY);
      ctx.lineTo(crossX + crossSize, crossY);
      ctx.stroke();
      // vertical
      ctx.beginPath();
      ctx.moveTo(crossX, crossY - crossSize);
      ctx.lineTo(crossX, crossY + crossSize);
      ctx.stroke();
      // small center dot
      ctx.fillStyle = crossColor;
      ctx.beginPath();
      ctx.arc(crossX, crossY, Math.max(1.5, 2 * (zoom || 1) * 0.6), 0, Math.PI * 2);
      ctx.fill();
    }

    const vignette = ctx.createRadialGradient(w / 2, h / 2, Math.min(w, h) * 0.12, w / 2, h / 2, Math.max(w, h) * 0.78);
    vignette.addColorStop(0, 'rgba(0,0,0,0)');
    vignette.addColorStop(0.55, 'rgba(0,0,0,0.18)');
    vignette.addColorStop(1, m.vignette);
    ctx.fillStyle = vignette;
    ctx.fillRect(0, 0, w, h);

    const near = nearestTarget();
    activeTargetName = near ? near.name : null;
    if (near) {
      pointingEl.textContent = `Looking at · ${near.name}`;
    } else {
      const ra = posMod((offsetX * -0.026), 24);
      const dec = Math.max(-90, Math.min(90, offsetY * -0.036));
      pointingEl.textContent = `Pointing · RA ${ra.toFixed(1)}h · Dec ${dec.toFixed(0)}°`;
    }
  }

  function animate() {
    draw(true);  // normal live view with reticle
    requestAnimationFrame(animate);
  }

  // Interaction
  canvas.addEventListener('mousedown', (e) => {
    isDragging = true;
    lastX = e.clientX;
    lastY = e.clientY;
    canvas.style.cursor = 'grabbing';
  });

  window.addEventListener('mouseup', () => {
    isDragging = false;
    canvas.style.cursor = 'grab';
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    // Damp pan when zoomed in so tiny movements don't fly across the magnified field (real eyepiece feel)
    const damp = 1.0 / Math.max(0.55, zoom);
    offsetX += (e.clientX - lastX) * 1.35 * damp;
    offsetY += (e.clientY - lastY) * 1.35 * damp;
    lastX = e.clientX;
    lastY = e.clientY;
  });

  // Touch support
  canvas.addEventListener('touchstart', (e) => {
    isDragging = true;
    lastX = e.touches[0].clientX;
    lastY = e.touches[0].clientY;
  }, { passive: true });

  canvas.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const damp = 1.0 / Math.max(0.55, zoom);
    offsetX += (e.touches[0].clientX - lastX) * 1.35 * damp;
    offsetY += (e.touches[0].clientY - lastY) * 1.35 * damp;
    lastX = e.touches[0].clientX;
    lastY = e.touches[0].clientY;
  }, { passive: true });

  canvas.addEventListener('touchend', () => {
    isDragging = false;
  });

  // Wheel zoom — real telescope "twist the focus / change eyepiece power"
  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.13 : 0.885;
    zoom = Math.max(0.35, Math.min(5.5, zoom * factor));
  }, { passive: false });

  // === Target buttons (clickable named views) ===
  function flyToTarget(target) {
    const targetX = target.offsetX;
    const targetY = target.offsetY;
    const startZoom = zoom;

    const startX = offsetX;
    const startY = offsetY;
    const duration = 920;
    const startTime = Date.now();

    // Simple visual feedback
    pointingEl.textContent = `Flying to ${target.name}...`;

    function step() {
      const elapsed = Date.now() - startTime;
      const t = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - t, 3.2);

      offsetX = startX + (targetX - startX) * ease;
      offsetY = startY + (targetY - startY) * ease;
      // Arrive at a comfortable default zoom so the full field + details read clearly
      zoom = startZoom + (1.0 - startZoom) * ease;

      if (t < 1) {
        requestAnimationFrame(step);
      } else {
        offsetX = targetX;
        offsetY = targetY;
        zoom = 1.0;
        pointingEl.textContent = `Looking at · ${target.name}`;
      }
    }
    step();
  }

  function setupTargets() {
    const container = document.getElementById('targets');
    if (!container) return;

    telescopeTargets.forEach(target => {
      const btn = document.createElement('button');
      btn.textContent = target.name;
      btn.className = 'text-left px-3 py-1.5 text-sm rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-mist-200 hover:text-mist-100 transition-colors';
      btn.title = target.note ? `Personal note: ${target.note.split('–')[0].trim()}` : target.name;  // fun personal note on hover only; button text stays clean and calm
      btn.addEventListener('click', () => flyToTarget(target));
      container.appendChild(btn);
    });
  }

  // Pinning
  function captureTelescopeView() {
    // Capture clean view of the current telescope canvas (no bullseye/reticle so it doesn't end up in the share image)
    draw(false);
    const thumb = canvas.toDataURL('image/jpeg', 0.72);
    draw(true);  // restore reticle for live view immediately

    const viewState = {
      lat: -offsetY * 0.035,
      lng: offsetX * 0.028,
      altitude: 2.1 + Math.random() * 0.3,
      spectrum: viewMode,
      zoom: zoom,  // capture exact magnification so real telescope views can be recreated from pins later
    };

    const pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
    const spectrumLabel = mode().label;
    const label = activeTargetName
      ? `${activeTargetName} · ${spectrumLabel}`
      : `Telescope · ${spectrumLabel}`;
    const newPin = {
      id: Date.now().toString(36),
      createdAt: new Date().toISOString(),
      viewState,
      label,
      note: activeTargetName
        ? (telescopeTargets.find(t => t.name === activeTargetName)?.note || `A quiet look at ${activeTargetName} through the telescope.`)
        : 'A quiet moment at the eyepiece',
      thumbnailData: thumb,
      source: 'telescope',
    };

    pins.unshift(newPin);
    localStorage.setItem('personalPins', JSON.stringify(pins));

    // Visual confirmation
    const toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #36415a;color:#e9edf5;padding:10px 20px;border-radius:9999px;font-size:13px;';
    toast.textContent = 'Pinned from the telescope';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2400);
  }

  pinBtn.addEventListener('click', captureTelescopeView);

  function updateModeUI() {
    const m = mode();
    const p = skyPhases[skyPhase] || skyPhases[2];
    if (modeDesc) modeDesc.textContent = m.desc + ' · ' + p.desc;
    if (modeBadge) modeBadge.textContent = m.label;
    if (phaseBadge) phaseBadge.textContent = p.label;
    if (eyepieceTint) {
      const tints = {
        visible: 'transparent',
        infrared: 'radial-gradient(ellipse at center, rgba(255,120,40,0.12) 0%, transparent 70%)',
        hydrogen: 'radial-gradient(ellipse at center, rgba(200,40,60,0.14) 0%, transparent 65%)',
        radio: 'radial-gradient(ellipse at center, rgba(80,120,255,0.08) 0%, transparent 75%)',
        deep: 'radial-gradient(ellipse at center, rgba(120,100,200,0.1) 0%, transparent 70%)',
      };
      eyepieceTint.style.background = tints[viewMode] || 'transparent';
      eyepieceTint.style.opacity = viewMode === 'visible' ? '0' : '1';
    }
    if (viewModesEl) {
      viewModesEl.querySelectorAll('[data-mode]').forEach((btn) => {
        const on = btn.getAttribute('data-mode') === viewMode;
        btn.classList.toggle('bg-amber-500/30', on);
        btn.classList.toggle('text-amber-50', on);
        btn.classList.toggle('border-amber-400/50', on);
        btn.classList.toggle('text-mist-400', !on);
        btn.classList.toggle('border-white/10', !on);
        btn.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }
  }

  function setViewMode(id) {
    if (!viewModes[id]) return;
    viewMode = id;
    try { sessionStorage.setItem('telescope-view-mode', id); } catch (_) {}
    updateModeUI();
  }

  function setSkyPhase(idx) {
    if (idx < 0 || idx > 4) return;
    skyPhase = idx;
    try { sessionStorage.setItem('telescope-sky-phase', idx); } catch (_) {}
    updateModeUI();
  }

  function buildViewModeButtons() {
    if (!viewModesEl) return;
    viewModesEl.innerHTML = '';
    Object.values(viewModes).forEach((m) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('data-mode', m.id);
      btn.setAttribute('role', 'tab');
      btn.title = `${m.label} (press ${m.key})`;
      btn.className =
        'px-2.5 py-1 text-[10px] rounded-full border transition-colors border-white/10 text-mist-400 hover:text-mist-100 hover:border-white/25';
      btn.textContent = m.label;
      btn.addEventListener('click', () => setViewMode(m.id));
      viewModesEl.appendChild(btn);
    });
  }

  // Keyboard: P pin, 1–5 eyepiece, 6-0 sky phases (sunset to sunrise)
  document.addEventListener('keydown', (e) => {
    const modeKeys = { '1': 'visible', '2': 'infrared', '3': 'hydrogen', '4': 'radio', '5': 'deep' };
    if (modeKeys[e.key]) {
      setViewMode(modeKeys[e.key]);
      return;
    }
    const phaseKeys = { '6': 0, '7': 1, '8': 2, '9': 3, '0': 4 };
    if (phaseKeys[e.key] !== undefined) {
      skyPhase = phaseKeys[e.key];
      updateModeUI();
      return;
    }
    if (e.key.toLowerCase() === 'p') {
      e.preventDefault();
      captureTelescopeView();
    }
  });

  // === Live camera selector + prominent view (per cottage spec) ===
  // Horizontal tabs below header. Main feed view large/centered/prominent.
  // Uses the sources from cameraSources (currently empty in this disabled/lab build).
  // Persists choice. Loading states on switch. Elegant "eyepiece" feel.
  // DISABLED STATE (Goldwing): tabs are hidden, cameraSources = [] in frontmatter.
  // Full wiring + video support + safety patches preserved for when good sky/space sources are provided.
  // Safety: never auto-open stored camera on load (prevents flashing/timelapse or bad feeds taking over).
  // Video sources: manual playback only, no auto-refresh, no autoplay, no loop.
  console.log('Camera JS initialized, found', cameraSources?.length, 'sources');
  let camVisible = false;
  let camLastRefresh = Date.now();
  let activeCam = null;
  let currentAutoRefresh = null;

  // cameraSources is provided via define:vars from the frontmatter (empty [] while disabled).
  // When good sources are vetted they will be populated and the hidden class removed from #live-cam-selector.

  function getStoredCamId() {
    try { return localStorage.getItem('observatory-active-cam'); } catch (_) { return null; }
  }
  function storeCamId(id) {
    try { localStorage.setItem('observatory-active-cam', id); } catch (_) {}
  }

  function updateCamUI(source) {
    if (!source) return;
    const nameEl = document.getElementById('cam-name');
    const creditEl = document.getElementById('cam-credit');
    const linkEl = document.getElementById('cam-page-link');
    if (nameEl) nameEl.textContent = source.name;
    if (creditEl) creditEl.textContent = source.credit;
    if (linkEl) {
      linkEl.href = source.pageUrl;
      linkEl.textContent = 'View full source page →';
    }
    const isVideo = source.kind === 'latest-video';
    if (camLiveImg) {
      camLiveImg.dataset.baseSrc = source.imageUrl || source.posterUrl || '';
      camLiveImg.alt = source.name + ' live feed';
      camLiveImg.classList.toggle('hidden', isVideo);
    }
    if (camLiveVideo) {
      camLiveVideo.classList.toggle('hidden', !isVideo);
      camLiveVideo.poster = source.posterUrl || '';
    }
    // Highlight active tab in the external selector
    document.querySelectorAll('#live-cam-selector [data-cam-id]').forEach(btn => {
      const on = btn.getAttribute('data-cam-id') === source.id;
      btn.classList.toggle('bg-amber-500/30', on);
      btn.classList.toggle('text-amber-50', on);
      btn.classList.toggle('border-amber-400/50', on);
      btn.classList.toggle('text-mist-300', !on);
      btn.classList.toggle('border-white/10', !on);
    });
  }

  function switchCamera(id, showPanel = true) {
    const src = cameraSources.find(s => s.id === id);
    if (!src) return;

    activeCam = src;
    storeCamId(id);
    updateCamUI(src);

    // Show loading state briefly
    const loading = document.getElementById('cam-loading');
    if (loading) loading.classList.remove('hidden');
    if (camFallback) camFallback.classList.add('hidden');

    // Load the feed immediately (per spec: start refreshing immediately on switch)
    loadActiveCameraImage();

    // Restart auto-refresh timer for this camera's refreshSeconds
    startAutoRefresh();

    if (showPanel) {
      showCameraPanel();
    }

    // Hide loading after a short delay (image load will also clear it)
    setTimeout(() => {
      if (loading) loading.classList.add('hidden');
    }, 650);
  }

  function loadActiveCameraImage() {
    console.log('Loading camera:', activeCam.name, 'URL:', activeCam.imageUrl || activeCam.videoUrl);
    if (!camLiveImg || !activeCam) return;
    const timestamp = Date.now();
    const isVideo = activeCam.kind === 'latest-video';
    const base = isVideo ? activeCam.videoUrl : activeCam.imageUrl;
    const sep = base.includes('?') ? '&' : '?';
    const nextSrc = `${base}${sep}t=${timestamp}`;
    if (isVideo && camLiveVideo) {
      camLiveImg.classList.add('hidden');
      camLiveVideo.classList.remove('hidden');
      camLiveVideo.src = nextSrc;
      camLiveVideo.poster = activeCam.posterUrl || '';
      camLiveVideo.load();
      console.log('Set video.src to:', camLiveVideo.src);
    } else {
      if (camLiveVideo) {
        camLiveVideo.pause();
        camLiveVideo.removeAttribute('src');
        camLiveVideo.classList.add('hidden');
      }
      camLiveImg.classList.remove('hidden');
      camLiveImg.src = nextSrc;
      console.log('Set img.src to:', camLiveImg.src);
    }
    camLiveImg.onload = () => console.log('Image loaded successfully');
    camLiveImg.onerror = () => console.log('Image failed to load');
    camLastRefresh = timestamp;
    updateCamTimestamp();
    if (camFallback) camFallback.classList.add('hidden');
    if (camLiveImg) camLiveImg.style.display = '';
    if (camLiveVideo) camLiveVideo.style.display = '';
  }

  function updateCamTimestamp() {
    const last = document.getElementById('cam-last-updated');
    if (!last) return;
    const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    last.textContent = `Last updated ${now}`;
  }

  function refreshCamImage() {
    if (!camLiveImg || !camRefreshBtn || !activeCam) return;
    camRefreshBtn.style.opacity = '0.6';
    camRefreshBtn.style.pointerEvents = 'none';
    loadActiveCameraImage();
    setTimeout(() => {
      if (camRefreshBtn) {
        camRefreshBtn.style.opacity = '1';
        camRefreshBtn.style.pointerEvents = 'auto';
      }
    }, 800);
  }

  function renderCamSelector() {
    // Tabs are pre-rendered server-side from cameraSources for guaranteed visibility.
    // This function now attaches click handlers and ensures initial active state.
    const container = document.querySelector('#live-cam-selector > div > div');
    if (!container) return;

    const buttons = container.querySelectorAll('[data-cam-id]');
    buttons.forEach((btn) => {
      const id = btn.getAttribute('data-cam-id');
      // Attach click if not already (for safety)
      if (!btn.dataset.listenerAttached) {
        btn.addEventListener('click', () => switchCamera(id));
        btn.dataset.listenerAttached = 'true';
      }
    });

    // Set initial active class based on stored or default (server sets first, this syncs)
    const storedId = getStoredCamId();
    const initialId = storedId || cameraSources[0]?.id;
    buttons.forEach((btn) => {
      const on = btn.getAttribute('data-cam-id') === initialId;
      btn.classList.toggle('bg-amber-500/30', on);
      btn.classList.toggle('text-amber-50', on);
      btn.classList.toggle('border-amber-400/50', on);
      btn.classList.toggle('text-mist-300', !on);
      btn.classList.toggle('border-white/10', !on);
    });
  }

  function showCameraPanel() {
    if (!camPanel) return;
    camPanel.classList.remove('hidden');
    camVisible = true;
    updateCamTimestamp();

    if (!activeCam) {
      const stored = getStoredCamId();
      activeCam = cameraSources.find(s => s.id === stored) || cameraSources[0];
    }
    updateCamUI(activeCam);

    if (camLiveImg && (!camLiveImg.getAttribute('src') || camLiveImg.src.includes('data:image'))) {
      loadActiveCameraImage();
    }

    startAutoRefresh();

    // Make live camera the prominent view, dim/hide procedural canvas and its UI
    if (mainRoot) mainRoot.classList.add('camera-mode');
    if (telescopeStage) {
      telescopeStage.style.transition = 'opacity 0.3s ease';
      telescopeStage.style.opacity = '0.15';
      telescopeStage.style.pointerEvents = 'none';
    }
    if (telescopeControls) telescopeControls.classList.add('hidden');
    if (modeDescEl) modeDescEl.classList.add('hidden');
    if (targetsEl) targetsEl.classList.add('hidden');

    // Expand camera panel to feel like the main/primary view
    if (camPanel) {
      camPanel.style.transition = 'all 0.3s ease-in-out';
      camPanel.style.width = 'min(90vw, 1000px)';
      camPanel.style.top = '70px';
      camPanel.style.maxHeight = 'calc(100vh - 100px)';
    }
  }

  function hideCameraPanel() {
    if (!camPanel) return;
    camPanel.classList.add('hidden');
    camVisible = false;
    if (currentAutoRefresh) {
      clearInterval(currentAutoRefresh);
      currentAutoRefresh = null;
    }

    // Restore procedural canvas to full view
    if (mainRoot) mainRoot.classList.remove('camera-mode');
    if (telescopeStage) {
      telescopeStage.style.opacity = '1';
      telescopeStage.style.pointerEvents = 'auto';
    }
    if (telescopeControls) telescopeControls.classList.remove('hidden');
    if (modeDescEl) modeDescEl.classList.remove('hidden');
    if (targetsEl) targetsEl.classList.remove('hidden');

    // Restore original camera panel size/position
    if (camPanel) {
      camPanel.style.width = '';
      camPanel.style.top = '105px';
      camPanel.style.maxHeight = 'calc(100vh - 160px)';
    }
  }

  // Wire controls
  const camCloseBtnEl = document.getElementById('cam-close-btn');
  if (camCloseBtnEl) {
    camCloseBtnEl.addEventListener('click', hideCameraPanel);
  }
  const camRefreshBtnEl = document.getElementById('cam-refresh-btn');
  if (camRefreshBtnEl && camLiveImg) {
    camRefreshBtnEl.addEventListener('click', refreshCamImage);

    camLiveImg.addEventListener('error', () => {
      const fb = document.getElementById('cam-fallback');
      if (fb) fb.classList.remove('hidden');
      if (camLiveImg) camLiveImg.style.display = 'none';
      const ld = document.getElementById('cam-loading');
      if (ld) ld.classList.add('hidden');
    });

    camLiveImg.addEventListener('load', () => {
      const fb = document.getElementById('cam-fallback');
      if (fb) fb.classList.add('hidden');
      if (camLiveImg) camLiveImg.style.display = '';
      const ld = document.getElementById('cam-loading');
      if (ld) ld.classList.add('hidden');
    });

    updateCamTimestamp();

    // Start dynamic auto-refresh based on the camera's refreshSeconds
    startAutoRefresh();
  }

  function startAutoRefresh() {
    if (currentAutoRefresh) clearInterval(currentAutoRefresh);
    if (!activeCam || !camVisible) return;
    if (activeCam.kind === 'latest-video' || activeCam.refreshSeconds === 0) return;
    const secs = activeCam.refreshSeconds || 60;
    currentAutoRefresh = setInterval(() => {
      if (camVisible && activeCam) {
        loadActiveCameraImage();
      }
    }, secs * 1000);
  }

  // Render tabs and set initial active (respect localStorage)
  renderCamSelector();

  activeCam = cameraSources[0];

  // Default to the first source, but do not auto-open a previously stored camera.
  // This prevents a stale/flashing media source from taking over the telescope on load.
  updateCamUI(activeCam);

  // Also wire any remaining old toggle if present (for backward)
  const oldCamToggle = document.getElementById('cam-toggle-btn');
  if (oldCamToggle) {
    oldCamToggle.addEventListener('click', () => {
      if (camVisible) hideCameraPanel();
      else showCameraPanel();
    });
  }

  // Boot
  try {
    const saved = sessionStorage.getItem('telescope-view-mode');
    if (saved && viewModes[saved]) viewMode = saved;
    const savedPhase = sessionStorage.getItem('telescope-sky-phase');
    if (savedPhase !== null) {
      const p = parseInt(savedPhase, 10);
      if (!isNaN(p) && p >= 0 && p <= 4) skyPhase = p;
    }
  } catch (_) {}

  initStars();
  buildViewModeButtons();
  setupTargets();
  updateModeUI();
  // ensure camera panel starts hidden
  if (camPanel) camPanel.classList.add('hidden');
  canvas.style.cursor = 'grab';
  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();
  animate();

  // Gentle encouragement
  setTimeout(() => {
    if (Math.random() > 0.6) {
      console.log('%c[Telescope] A reminder: the best views are the ones you return to.', 'color:#5f6b85;font-size:10px');
    }
  }, 8000);
</script>
