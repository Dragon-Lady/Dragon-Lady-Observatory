---
import Base from '@/layouts/Base.astro';
import CameraPanel from '@/components/CameraPanel.astro';
import { cameraSources } from '@/lib/cameraSources';

const base = import.meta.env.BASE_URL;
---

<Base title="Camera Test · Dragon Lady’s Observatory">
  <div class="min-h-screen bg-[#05070d] p-8">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center gap-3 mb-8">
        <a href={base + 'telescope'} class="text-mist-400 hover:text-mist-200 text-sm">← back to telescope</a>
        <div class="text-mist-100 font-semibold tracking-tight text-2xl">Camera Test</div>
      </div>
      
      <div class="grid gap-6">
        <CameraPanel source={cameraSources[0]} />
      </div>
      
      <div class="mt-8 text-mist-400 text-sm">
        This is a test page for the CameraPanel component. 
        If this loads successfully, we can wire it into the main telescope page.
      </div>
    </div>
  </div>
</Base>
