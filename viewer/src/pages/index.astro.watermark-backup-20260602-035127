---
import Base from '@/layouts/Base.astro';
import RecordCard from '@/components/RecordCard.astro';
import { allRecords, stats, domainsPresent, loadCatalog } from '@/lib/store';
import { DOMAIN_LABEL } from '@/lib/display';
import type { Domain } from '@/types';

const records = allRecords();
const s = stats();
const present = domainsPresent();
const allDomains: Domain[] = ['orbital', 'neo', 'space_weather', 'launch_reentry'];
const base = import.meta.env.BASE_URL;
const catalogCount = loadCatalog().length;
---

<Base title="Dragon Lady’s Observatory">
  <!-- celestial hero -->
  <section class="sky -mx-4 mb-6 rounded-none border-b border-void-800 px-4 py-10 sm:rounded-xl sm:border">
    <div class="relative z-10 max-w-2xl">
      <h1 class="text-2xl font-semibold tracking-tight text-mist-100 sm:text-3xl">The sky, watched.</h1>
      <p class="mt-1 text-xs text-mist-500">Your personal observatory in the night sky.</p>
      <p class="mt-3 text-mist-300">
        A calm place to explore what’s overhead — satellites, stars, and quiet moments worth noticing.
      </p>
      <div class="mt-5 flex flex-wrap gap-4 text-sm text-mist-400">
        <span><strong class="text-mist-100">{s.total}</strong> things overhead</span>
        <span><strong class="text-mist-100">{s.anomalies}</strong> quiet moments saved</span>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href={base + 'telescope'} class="inline-flex items-center gap-2 rounded-md bg-mist-100 px-6 py-2.5 text-sm font-semibold !text-void-950 hover:!no-underline hover:bg-white active:scale-[0.985] transition-all">
          🔭 Open the telescope
        </a>
        <a href={base + 'globe'} class="inline-flex items-center gap-2 rounded-md border border-void-700 px-5 py-2.5 text-sm font-medium text-mist-200 hover:bg-emerald-900/20 hover:border-emerald-700 hover:text-emerald-300 transition-colors">
          🌍 The globe
        </a>
        <a href={base + 'sky-events'} class="inline-flex items-center gap-2 rounded-md border border-void-700 px-5 py-2.5 text-sm font-medium text-mist-200 hover:bg-emerald-900/20 hover:border-emerald-700 hover:text-emerald-300 transition-colors">
          ✨ Sky events
        </a>
      </div>
    </div>
  </section>

  <!-- Your Observatory (primary personal experience) -->
  <section class="mb-8">
    <div class="mb-4">
      <h2 class="text-xl font-semibold text-mist-100">Your observatory</h2>
      <p class="text-xs text-mist-500 mt-0.5">The places in the sky that matter to you.</p>
    </div>

    <!-- My Pins Section -->
    <div class="mb-6">
      <!-- Collection Filter Chips -->
      <div class="mb-3 flex flex-wrap gap-2" id="pins-chips">
        <!-- Chips start neutral; JS controls active state on load and clicks -->
        <button data-chip="all" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">All moments</button>
        <button data-chip="favorites" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">Favorites shelf</button>
        <button data-chip="sky-events" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">From Sky Events</button>
        <button data-chip="quiet" class="chip px-3 py-1 text-sm rounded-full border border-void-700 bg-void-900 text-mist-300 hover:border-void-500">Quiet revisit</button>
      </div>
      <div id="chip-hint" class="hidden mb-3 text-xs text-mist-400"></div>

      <!-- Vault Migration Banner -->
      <div id="vault-banner" class="hidden mb-4 rounded-xl border border-void-700 bg-void-900 p-5" onclick="event.stopImmediatePropagation()">
        <div class="text-mist-200 mb-3">You have a backup of your pins in the vault. Would you like to bring them into this browser?</div>
        <div class="flex gap-3">
          <button id="bring-home" class="px-4 py-1.5 text-sm rounded-lg bg-signal-400 text-void-950 font-medium">Bring them home</button>
          <button id="not-now" class="px-4 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300">Not now</button>
        </div>
      </div>

      <div class="mb-4 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <input id="pins-search" type="text" placeholder="Find a saved view..."
                 class="text-sm px-3 py-1.5 rounded-lg border border-void-700 bg-void-900 text-mist-200 placeholder:text-mist-500 focus:outline-none focus:border-void-500" style="width:180px;">
          <button id="clear-search" class="text-xs text-mist-500 hover:text-mist-300">clear</button>
          <select id="pins-sort" class="text-sm px-3 py-1.5 rounded-lg border border-void-700 bg-void-900 text-mist-200 focus:outline-none focus:border-void-500">
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="favorites">Favorites first</option>
          </select>
        </div>
        <div class="flex gap-2 text-sm">
          <button id="save-vault" class="px-3 py-1.5 rounded-lg border border-void-700 text-mist-300 hover:bg-void-800">Save to vault</button>
          <button id="export-pins" class="px-3 py-1.5 rounded-lg border border-void-700 text-mist-300 hover:bg-void-800">Export my pins</button>
          <label class="px-3 py-1.5 rounded-lg border border-void-700 text-mist-300 hover:bg-void-800 cursor-pointer">
            Import pins
            <input type="file" id="import-pins" accept=".json" class="hidden" />
          </label>
        </div>
      </div>

      <!-- Rediscover Strip -->
      <div id="rediscover-strip" class="hidden mb-5 rounded-xl border border-void-700 bg-void-900 p-4">
        <div class="text-xs text-mist-400 mb-2">Some quiet views waiting for you</div>
        <div id="rediscover-items" class="flex flex-wrap gap-3 text-sm"></div>
      </div>

      <div id="pins-grid" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Populated by script below -->
      </div>

      <div id="pins-empty" class="hidden rounded-xl border border-dashed border-void-700 p-8 text-center">
        <p class="text-mist-300">No pins yet. Open the globe and press <strong>P</strong> on anything beautiful.</p>
      </div>

      <div id="pins-no-results" class="hidden col-span-full text-center text-mist-400 text-sm py-6">
        No pins match your search.
      </div>

      <div class="mt-2 text-sm text-mist-400">Last write to the vault wins. Your pins are always yours.</div>
    </div>
  </section>

  <!-- Telescope -->
  <section class="mb-4">
    <a href={base + 'telescope'} class="block rounded-2xl border border-emerald-800/50 bg-emerald-950/10 p-6 hover:border-emerald-700 hover:bg-emerald-950/20 transition-all group">
      <div class="flex items-center justify-between">
        <div>
          <div class="font-medium text-mist-100 text-lg group-hover:text-emerald-300 transition-colors">The Telescope</div>
          <p class="mt-1 text-sm text-mist-300">A calm place to look up. No satellites. No noise. Just sky.</p>
        </div>
        <span class="text-emerald-400 text-sm">Open →</span>
      </div>
    </a>
  </section>

  <!-- Sky Events teaser -->
  <section class="mb-8">
    <a href={base + 'sky-events'} class="block rounded-2xl border border-void-700 bg-void-900 p-6 hover:border-void-500 transition-colors">
      <div class="flex items-center justify-between">
        <div>
          <div class="font-medium text-mist-100 text-lg">Sky Events</div>
          <p class="mt-1 text-sm text-mist-300">Constellations and quiet moments worth noticing tonight and soon.</p>
        </div>
        <span class="text-signal-400 text-sm">Explore →</span>
      </div>
    </a>
  </section>

  <!-- Everything overhead (optional) — collapsed by default -->
  <details class="mb-6">
    <summary class="cursor-pointer text-sm text-mist-400 hover:text-mist-200 mb-4 select-none">
      Everything overhead (optional)
    </summary>

    <!-- layer toggles + tier legend (de-emphasized) -->
    <div class="mb-4 flex flex-wrap items-center justify-between gap-3 opacity-85">
      <div class="flex flex-wrap items-center gap-2">
        <button class="layer-btn active rounded-full border border-signal-400 bg-void-800 px-3 py-1 text-sm !text-mist-100" data-layer="all">All</button>
        {allDomains.map((d) => (
          <button
            class="layer-btn rounded-full border border-void-700 bg-void-900 px-3 py-1 text-sm text-mist-300 disabled:opacity-40"
            data-layer={d}
            disabled={!present.includes(d)}
            title={present.includes(d) ? '' : 'no data yet'}
          >{DOMAIN_LABEL[d]}</button>
        ))}
      </div>
      <div class="flex items-center gap-3 text-xs text-mist-400/80" title="Tiers reflect interest level, not urgency.">
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t1"></span>T1</span>
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t2"></span>T2</span>
        <span class="flex items-center gap-1"><span class="inline-block h-1.5 w-1.5 rounded-full dot-t3"></span>T3</span>
      </div>
    </div>

    <!-- browse-catalog hatch (softened) -->
    <a href={base + 'catalog'} class="mb-4 flex items-center justify-between rounded-lg border border-void-800 bg-void-900 px-4 py-3 text-sm hover:border-void-600 hover:!no-underline opacity-85">
      <span class="!text-mist-200">🛰 Browse everything up there — <strong class="text-mist-100">{catalogCount.toLocaleString()}</strong> things overhead</span>
      <span class="text-signal-400">search →</span>
    </a>

    {records.length === 0 ? (
      <div class="rounded-lg border border-dashed border-void-700 p-8 text-center">
        <p class="text-mist-300">The sky feels quiet right now. Take your time exploring.</p>
      </div>
    ) : (
      <div id="grid" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {records.map((r) => <RecordCard record={r} />)}
      </div>
    )}

    <script is:inline>
      const btns = document.querySelectorAll('.layer-btn');
      const cards = document.querySelectorAll('.record-card');
      btns.forEach((b) => b.addEventListener('click', () => {
        const layer = b.dataset.layer;
        btns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('active', on);
          x.classList.toggle('border-signal-400', on);
          x.classList.toggle('!text-mist-100', on);
          x.classList.toggle('border-void-700', !on);
          x.classList.toggle('text-mist-300', !on);
        });
        cards.forEach((c) => {
          c.style.display = (layer === 'all' || c.dataset.domain === layer) ? '' : 'none';
        });
      }));
    </script>
  </details>

  <script is:inline define:vars={{ base }}>
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
    '&': '&amp;',
    '<': '&lt;',
    '>': '&gt;',
    '"': '&quot;',
    "'": '&#39;',
  }[char]));

  const safeNumber = (value, fallback = 0) => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  };

  let activeChip = 'all';

  function getDaysSince(dateStr) {
    if (!dateStr) return 9999;
    return Math.floor((Date.now() - new Date(dateStr).getTime()) / (1000 * 60 * 60 * 24));
  }

  function applyCollectionFilter(pins, chip) {
    if (chip === 'all') return pins;
    if (chip === 'favorites') return pins.filter(p => p.favorite);
    if (chip === 'sky-events') return pins.filter(p => p.sourceEventId);
    if (chip === 'quiet') {
      return pins.filter(p => {
        const date = p.updatedAt || p.createdAt;
        return getDaysSince(date) > 30;
      });
    }
    return pins;
  }

  /**
   * Creates the shareable Observatory card for a pin.
   *
   * Final direction:
   * - The globe (3D Earth + satellite tracks, markers, data layers) is "noise".
   * - The desired "telescope / observatory angle" for sharing is the calm, contemplative, wonder-filled artistic sky.
   * - Globe canvas thumbnails are NEVER included in the exported image (they are meaningless even to the creator later).
   * - Every share is a pure, self-contained artistic Observatory card: rich gradient sky + stars + minimal poetic text + the two watermarks.
   *
   * Watermarks (locked rules):
   * - Default faint dragon: bottom left, always present, cannot be turned off.
   * - Personal Dragon Lady mark (Tanya): top right for creator pins.
   */
  async function createShareableImage(pin) {
    const viewState = pin.viewState || {};
    const lat = safeNumber(viewState.lat);
    const lng = safeNumber(viewState.lng);
    const label = pin.label || 'Saved View';
    const dateStr = pin.createdAt ? new Date(pin.createdAt).toLocaleDateString() : '';
    const isTelescope = pin.source === 'telescope' && !!pin.thumbnailData;
    const spectrum = viewState.spectrum ? String(viewState.spectrum).toUpperCase() : '';

    // Core background painter — rich gradient + subtle stars (never pure black). Used for non-telescope or fallback.
    function drawRichSky(ctx, w, h) {
      const hue = Math.floor(((lat + 90) / 180) * 360);
      const sat = 38 + Math.floor(Math.abs(lng) % 35);
      const light = 32 + Math.floor(Math.abs(lat) % 18);

      // Slightly brighter night gradient so stars and text read well
      const g = ctx.createLinearGradient(0, 0, w, h);
      g.addColorStop(0, `hsl(${hue}, ${sat + 8}%, ${Math.max(16, light + 2)}%)`);
      g.addColorStop(1, `hsl(${hue + 22}, ${sat + 2}%, ${Math.max(10, light - 8)}%)`);
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, w, h);

      // Deterministic stars (same pin = same quiet field)
      ctx.fillStyle = 'rgba(233,237,245,0.6)';
      const starSeed = Math.floor(Math.abs(lat) * 100 + Math.abs(lng) * 17) % 200;
      for (let i = 0; i < 52; i++) {
        const x = ((starSeed + i * 37) % (w - 36)) + 18;
        const y = ((starSeed + i * 19) % (h - 120)) + 18;
        const r = ((i % 3) === 0) ? 1.15 : 0.65;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Full pretty card used when there is no usable telescope thumbnail.
    function drawPrettyFallback(ctx, w, h, dragonImg, ladyImg) {
      drawRichSky(ctx, w, h);

      ctx.fillStyle = '#e9edf5';
      ctx.font = 'bold 32px system-ui';
      ctx.fillText(label, 48, h * 0.38);

      ctx.font = '18px system-ui';
      ctx.fillStyle = '#aab4c7';
      ctx.fillText(dateStr ? `Pinned ${dateStr}` : 'A quiet view worth keeping', 48, h * 0.38 + 38);

      // Watermarks in the correct corners (passed in)
      drawWatermarks(ctx, w, h, dragonImg, ladyImg);
    }

    // === Watermark marks (locked rules) ===
    // Default faint dragon (bottom left, always present, cannot be turned off).
    // Personal Dragon Lady mark (Tanya photo-style companion, top right for creator pins).
    // Hybrid: soft Imagine JPG underlay (for artistic generated texture) + clean recognizable canvas silhouettes on top (for clear "Dragon" and "Dragon Lady" forms).
    // The Imagine assets provide the soft quality; the silhouettes (detailed paths) guarantee they read correctly while staying faint. Dragon: snout + 2 horns + multi-finger wing + belly + 3 tail spikes. Lady: head + flowing hair lines + elegant body + small dragon companion.
    //
    // SAVE POINT 2026-06-02 (low credits ~6%, rate limit risk) - UPDATED with new usage info + fixes:
    // - Free credits with SuperGrok: 95% used · Resets Jun 30
    // - Pay-as-you-go: $0.00 used of $50.00 limit (added as fallback)
    // - Moon telescope pin share card: watermarks appear as empty "boxes" in corners (top right + left? / bottom left)
    //   instead of the Imagine assets. Because generated JPGs have solid (white) backgrounds, not cutouts.
    // - Fallback paths are basic curves, not matching the desired faint dragon / lady marks.
    // - Telescope real capture + artistic veil + text is working for the Moon shot.
    // - DO NOT use more Imagine credits if possible. Fix via client-side processing.
    // - User: "wonder how long that lasts and if it goes to my pay-per-use tier like the cottage does."
    //   Note: Cottage uses separate pay-per-use API key (local James CLI / Grok.ps1). This $50 is grok.com/SuperGrok pay-as-you-go for web Imagine usage (different tier/billing from cottage).
    // - User has screenshot of the bad Moon share. Pick up from here.
    // - We only have 6% free credits left — hate rate limits too. Saved state in cottage.
    // - Fix implemented (client-side, no extra credits): hybrid but Imagine underlay at *extremely low* alpha (0.05) because generated assets were not reading as dragon/lady (rabbit/squid per user).
    //   Clean, recognizable canvas silhouettes are the main (detailed paths: dragon with long snout, 2 horns, eye, wing not too high to avoid rabbit-ear, belly, tail + 3 spikes; lady with head, 1 main hair flow, neck/shoulder, elegant body, small clear dragon companion with head/horn/wing/tail).
    //   Text caption at x=160 to keep the bottom-left corner exclusively for the dragon watermark (no more "tag" like "Full Moon · Visible" dominating the corner).
    //   Watermark sizes increased (dragon 120x90 @ x=20, lady 100x85 @ top-right), alphas 0.38/0.40.
    //   Fallbacks use the same silhouettes.
    //   Result: should now clearly read as a (faint) Dragon bottom-left and recognizable Dragon Lady mark top-right. Imagine provides only very subtle artistic texture.
    // - Updated with user credit status: Free 95% used (resets Jun 30), Pay-as-you-go $50 added ($0 used). Cottage pay-per-use is separate (local key). This $50 affects grok.com web usage (Imagine etc.). We will monitor how long it lasts in practice.
    //
    // ITER 3 (post-giggle): "*can't help but giggle* hmmm this just gets funnier. Yours is...not a dragon at all and mine is...a squid maybe?"
    //   (after prior "almost looks like a Dragon", "something but I don't know what", "squiggles", "hidden rabbit")
    //   Further whole-fn refinement of drawDragonSilhouette + drawLadyMarkSilhouette (no Imagine spend):
    //   Dragon: long low body profile, distinct long snout + 2 horns from crown, swept wing (back first then moderate rise), 3 clearly separate back-trailing bony fingers (not up/ear), belly + small leg/claw for mass, long tail + 3 triangular dorsal barbs/spikes.
    //   Lady mark: head + 3 individual distinct hair bezier flows (different start points/arcs/lengths so clearly strands not mass or tentacles), short neck to shoulder, clear separated feminine torso curve, then GAP + compact separate companion dragon (head/snout/horn/eye + small wing + tail flick + barb) that reads as tiny dragon not blended squiggle.
    //   Silhouette alphas kept ~0.38-0.40, underlay JPG still 0.05 (near invisible, silhouette is definition now). Line widths bumped 2.0/1.8 for readability at faintness.
    //   Text x=160 and positions locked. Hybrid preserved. Ready for sync + live retest on fresh Moon (or other) share card. If still not reading we ask user before any other path.

    async function loadWatermarkAssets() {
      const dragonImg = new Image();
      const ladyImg = new Image();
      const dragonSrc = '/watermarks/dragon-watermark.jpg';
      const ladySrc = '/watermarks/dragon-lady-mark.jpg';

      await Promise.all([
        new Promise((resolve, reject) => {
          dragonImg.onload = resolve;
          dragonImg.onerror = () => {
            console.warn('Could not load dragon watermark, falling back to simple draw');
            resolve(); // continue even if fails
          };
          dragonImg.src = dragonSrc;
        }),
        new Promise((resolve, reject) => {
          ladyImg.onload = resolve;
          ladyImg.onerror = () => {
            console.warn('Could not load dragon lady mark, falling back to simple draw');
            resolve();
          };
          ladyImg.src = ladySrc;
        })
      ]);

      // Client-side processing to remove white-ish backgrounds from the Imagine JPGs
      // This turns the "boxes" into proper faint transparent watermarks without needing new generations (saves credits)
      const processedDragon = await processImageForTransparentBg(dragonImg);
      const processedLady = await processImageForTransparentBg(ladyImg);

      return { dragonImg: processedDragon, ladyImg: processedLady };
    }

    // Processes a loaded image (typically JPG with white bg from Imagine) and returns a new Image
    // with near-white pixels made transparent. This fixes the empty box appearance in share cards.
    async function processImageForTransparentBg(originalImg) {
      if (!originalImg || !originalImg.complete || originalImg.naturalWidth === 0) {
        return originalImg; // fallback to original if bad
      }
      return new Promise((resolve) => {
        const offCanvas = document.createElement('canvas');
        offCanvas.width = originalImg.naturalWidth || originalImg.width;
        offCanvas.height = originalImg.naturalHeight || originalImg.height;
        const offCtx = offCanvas.getContext('2d', { willReadFrequently: true });
        offCtx.drawImage(originalImg, 0, 0, offCanvas.width, offCanvas.height);

        const imageData = offCtx.getImageData(0, 0, offCanvas.width, offCanvas.height);
        const data = imageData.data;
        const threshold = 245; // more conservative: only remove very pure white bg
        const softness = 15;

        for (let i = 0; i < data.length; i += 4) {
          const r = data[i];
          const g = data[i + 1];
          const b = data[i + 2];
          const avg = (r + g + b) / 3;

          if (avg > threshold) {
            // very pure white bg -> transparent
            data[i + 3] = 0;
          } else if (avg > threshold - softness) {
            // soft edge fade for near-white
            const fade = Math.max(0, (avg - (threshold - softness)) / softness);
            data[i + 3] = Math.floor(data[i + 3] * (1 - fade));
          } else {
            // the mark area: keep full opacity, slight darken for better contrast on dark card
            const boost = 0.85;
            data[i] = Math.max(0, Math.min(255, Math.floor(r * boost)));
            data[i + 1] = Math.max(0, Math.min(255, Math.floor(g * boost)));
            data[i + 2] = Math.max(0, Math.min(255, Math.floor(b * boost)));
            data[i + 3] = 255;
          }
        }

        offCtx.putImageData(imageData, 0, 0);

        const processed = new Image();
        processed.onload = () => resolve(processed);
        processed.onerror = () => resolve(originalImg); // fallback
        processed.src = offCanvas.toDataURL('image/png'); // use PNG for transparency
      });
    }

    // Helper: draw a clean, recognizable faint dragon silhouette (side view)
    // Layered on top of the soft Imagine asset (ultra-low alpha) for definition while keeping artistic feel.
    // Refined after live giggle feedback ("not a dragon at all", "squid maybe"): iconic side-profile dragon
    // with long snout + 2 distinct horns, swept-back bat/dragon wing with 3 clearly separate trailing fingers
    // (not ear-like), belly mass + small leg/claw hint, long tapering tail with 3 dorsal barbed spikes.
    // More angular/characteristic dragon reading at small faint size.
    function drawDragonSilhouette(ctx, x, y, scale, alpha) {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = '#e9edf5';
      ctx.fillStyle = '#e9edf5';
      ctx.lineWidth = 2.0 * scale;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';

      const s = scale;

      // Long low body from tail root (horizontal dragon profile)
      ctx.beginPath();
      ctx.moveTo(x + 5*s, y + 68*s);
      ctx.bezierCurveTo(x + 25*s, y + 55*s, x + 55*s, y + 48*s, x + 85*s, y + 52*s);
      ctx.bezierCurveTo(x + 105*s, y + 50*s, x + 118*s, y + 48*s, x + 128*s, y + 54*s);
      ctx.stroke();

      // Belly mass (separate underline for volume)
      ctx.beginPath();
      ctx.moveTo(x + 10*s, y + 64*s);
      ctx.bezierCurveTo(x + 40*s, y + 60*s, x + 70*s, y + 58*s, x + 120*s, y + 60*s);
      ctx.stroke();

      // Small leg/claw hint (adds quadruped mass, helps dragon read)
      ctx.beginPath();
      ctx.moveTo(x + 95*s, y + 58*s);
      ctx.lineTo(x + 100*s, y + 68*s);
      ctx.moveTo(x + 100*s, y + 68*s);
      ctx.lineTo(x + 108*s, y + 66*s);
      ctx.stroke();

      // Neck rising to head
      ctx.beginPath();
      ctx.moveTo(x + 128*s, y + 54*s);
      ctx.bezierCurveTo(x + 135*s, y + 48*s, x + 138*s, y + 40*s, x + 132*s, y + 34*s);
      ctx.stroke();

      // Head with long forward snout (upper jaw + jawline distinct)
      ctx.beginPath();
      ctx.moveTo(x + 132*s, y + 34*s);
      ctx.bezierCurveTo(x + 142*s, y + 28*s, x + 158*s, y + 30*s, x + 162*s, y + 40*s); // upper snout
      ctx.bezierCurveTo(x + 158*s, y + 46*s, x + 145*s, y + 48*s, x + 132*s, y + 42*s); // lower jaw
      ctx.stroke();

      // 2 clear horns from crown (distinct, not merged)
      ctx.beginPath();
      ctx.moveTo(x + 138*s, y + 32*s); ctx.lineTo(x + 145*s, y + 20*s); // tall main horn
      ctx.moveTo(x + 142*s, y + 33*s); ctx.lineTo(x + 150*s, y + 24*s); // second horn
      ctx.stroke();

      // Eye (small, side of head)
      ctx.beginPath();
      ctx.arc(x + 142*s, y + 38*s, 2.2*s, 0, Math.PI * 2);
      ctx.fill();

      // Wing: shoulder attach mid-back, swept back first then moderate up (bat/dragon not rabbit)
      ctx.beginPath();
      ctx.moveTo(x + 72*s, y + 50*s); // attach point
      ctx.bezierCurveTo(x + 55*s, y + 42*s, x + 48*s, y + 28*s, x + 62*s, y + 18*s); // to wrist
      ctx.stroke();

      // 3 distinct trailing wing fingers (bony, back-pointing, clearly wing not ears)
      ctx.beginPath();
      ctx.moveTo(x + 58*s, y + 26*s); ctx.lineTo(x + 32*s, y + 8*s); ctx.stroke();  // finger 1 longest
      ctx.beginPath();
      ctx.moveTo(x + 60*s, y + 24*s); ctx.lineTo(x + 38*s, y + 14*s); ctx.stroke();  // finger 2
      ctx.beginPath();
      ctx.moveTo(x + 62*s, y + 22*s); ctx.lineTo(x + 48*s, y + 18*s); ctx.stroke();  // finger 3

      // subtle membrane between for structure (soft connect)
      ctx.beginPath();
      ctx.moveTo(x + 32*s, y + 8*s);
      ctx.quadraticCurveTo(x + 40*s, y + 14*s, x + 48*s, y + 18*s);
      ctx.stroke();

      // Tail long tapering + flick + 3 dorsal barbed spikes
      ctx.beginPath();
      ctx.moveTo(x + 5*s, y + 68*s);
      ctx.bezierCurveTo(x - 8*s, y + 78*s, x - 4*s, y + 92*s, x + 22*s, y + 95*s);
      ctx.stroke();

      // spike 1 (triangular barb)
      ctx.beginPath();
      ctx.moveTo(x + 2*s, y + 78*s); ctx.lineTo(x - 1*s, y + 72*s); ctx.lineTo(x + 6*s, y + 77*s); ctx.stroke();
      // spike 2
      ctx.beginPath();
      ctx.moveTo(x + 6*s, y + 84*s); ctx.lineTo(x + 2*s, y + 79*s); ctx.lineTo(x + 10*s, y + 83*s); ctx.stroke();
      // spike 3 near tip
      ctx.beginPath();
      ctx.moveTo(x + 14*s, y + 91*s); ctx.lineTo(x + 10*s, y + 86*s); ctx.lineTo(x + 18*s, y + 90*s); ctx.stroke();

      ctx.restore();
    }

    // Helper: draw a clean, recognizable faint "Dragon Lady" personal mark (top-right creator)
    // Elegant paired form: graceful woman (head, 3 distinct separate flowing hair strands, neck/shoulders,
    // clear feminine torso) + small but obviously separate compact dragon companion to the right
    // (own head/snout/horn/eye + wing + tail with barb). After squid feedback: hair strands clearly
    // individual (different starts/arcs/ends), torso separated from hair, companion dragon compact
    // and draconic with gap, not blended lines.
    function drawLadyMarkSilhouette(ctx, x, y, scale, alpha) {
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = '#f4e9d8';
      ctx.fillStyle = '#f4e9d8';
      ctx.lineWidth = 1.8 * scale;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';

      const s = scale;

      // Head (portrait element)
      ctx.beginPath();
      ctx.arc(x + 26*s, y + 26*s, 10*s, 0, Math.PI * 2);
      ctx.stroke();

      // 3 distinct long flowing hair strands (separate elegant flows, not one squid mass)
      // back/left long flow
      ctx.beginPath();
      ctx.moveTo(x + 20*s, y + 20*s);
      ctx.bezierCurveTo(x + 8*s, y + 32*s, x + 2*s, y + 50*s, x + 6*s, y + 72*s);
      ctx.stroke();
      // mid flow
      ctx.beginPath();
      ctx.moveTo(x + 24*s, y + 18*s);
      ctx.bezierCurveTo(x + 14*s, y + 30*s, x + 10*s, y + 48*s, x + 14*s, y + 70*s);
      ctx.stroke();
      // side/right flow
      ctx.beginPath();
      ctx.moveTo(x + 30*s, y + 19*s);
      ctx.bezierCurveTo(x + 38*s, y + 28*s, x + 44*s, y + 44*s, x + 40*s, y + 68*s);
      ctx.stroke();

      // Neck + shoulder slope (feminine silhouette)
      ctx.beginPath();
      ctx.moveTo(x + 26*s, y + 35*s);
      ctx.quadraticCurveTo(x + 22*s, y + 42*s, x + 24*s, y + 50*s);
      ctx.stroke();

      // Clear torso / body curve (distinct woman form, separated from hair lines)
      ctx.beginPath();
      ctx.moveTo(x + 24*s, y + 50*s);
      ctx.bezierCurveTo(x + 28*s, y + 58*s, x + 36*s, y + 62*s, x + 48*s, y + 58*s);
      ctx.bezierCurveTo(x + 58*s, y + 64*s, x + 68*s, y + 60*s, x + 76*s, y + 52*s);
      ctx.stroke();

      // Small compact companion dragon (clear gap after lady body; obviously dragon not continuation)
      const dx = x + 82*s, dy = y + 48*s;
      // body + to head
      ctx.beginPath();
      ctx.moveTo(dx + 4*s, dy + 8*s);
      ctx.bezierCurveTo(dx + 12*s, dy + 2*s, dx + 20*s, dy + 4*s, dx + 24*s, dy + 10*s);
      ctx.stroke();
      // head + snout
      ctx.beginPath();
      ctx.moveTo(dx + 24*s, dy + 10*s);
      ctx.bezierCurveTo(dx + 28*s, dy + 6*s, dx + 32*s, dy + 7*s, dx + 30*s, dy + 12*s);
      ctx.stroke();
      // horn
      ctx.beginPath();
      ctx.moveTo(dx + 27*s, dy + 7*s); ctx.lineTo(dx + 29*s, dy + 2*s); ctx.stroke();
      // eye
      ctx.beginPath();
      ctx.arc(dx + 26*s, dy + 9*s, 1.2*s, 0, Math.PI * 2);
      ctx.fill();
      // small wing up (distinct)
      ctx.beginPath();
      ctx.moveTo(dx + 14*s, dy + 6*s); ctx.lineTo(dx + 16*s, dy - 2*s); ctx.lineTo(dx + 20*s, dy + 3*s); ctx.stroke();
      // tail flick + tiny barb
      ctx.beginPath();
      ctx.moveTo(dx + 4*s, dy + 8*s);
      ctx.bezierCurveTo(dx - 2*s, dy + 12*s, dx - 6*s, dy + 18*s, dx - 2*s, dy + 20*s);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(dx - 2*s, dy + 14*s); ctx.lineTo(dx - 5*s, dy + 12*s); ctx.lineTo(dx - 1*s, dy + 16*s); ctx.stroke();

      ctx.restore();
    }

    // Draw both watermarks in the correct corners per locked rules.
    // Layer: soft Imagine artistic base (if available) + clean recognizable canvas silhouette on top for definition.
    // This gives the "high quality artistic" feel from Imagine while guaranteeing they read as a Dragon and Dragon Lady mark.
    function drawWatermarks(ctx, w, h, dragonImg, ladyImg) {
      // Default faint dragon — bottom left, always
      if (dragonImg && dragonImg.complete && dragonImg.naturalWidth > 0) {
        ctx.save();
        ctx.globalAlpha = 0.05; // extremely soft artistic underlay from Imagine (the generated one was not reading as dragon)
        const dw = 120;
        const dh = 90;
        ctx.drawImage(dragonImg, 20, h - dh - 15, dw, dh);
        ctx.restore();
      }
      // Always draw the clean silhouette on top for clear "dragon" recognition
      drawDragonSilhouette(ctx, 20, h - 95, 1.0, 0.38);

      // Personal Dragon Lady mark — top right
      if (ladyImg && ladyImg.complete && ladyImg.naturalWidth > 0) {
        ctx.save();
        ctx.globalAlpha = 0.05; // extremely soft artistic underlay from Imagine (the generated one was not reading as lady mark)
        const lw = 100;
        const lh = 85;
        ctx.drawImage(ladyImg, w - lw - 20, 20, lw, lh);
        ctx.restore();
      }
      // Always draw the clean silhouette on top for clear recognition
      drawLadyMarkSilhouette(ctx, w - 110, 20, 1.0, 0.40);
    }

    const canvas = document.createElement('canvas');
    canvas.width = 1200;
    canvas.height = 820;
    const ctx = canvas.getContext('2d');

    // Load Imagine watermarks (async safe)
    const { dragonImg, ladyImg } = await loadWatermarkAssets();

    if (isTelescope) {
      // Real telescope capture as the heart of the share card (observatory angle).
      // Watermarks (Imagine assets) overlaid faint in locked corners. Minimal poetic text.
      const baseImg = new Image();
      await new Promise((resolve, reject) => {
        baseImg.onload = resolve;
        baseImg.onerror = reject;
        baseImg.src = pin.thumbnailData;
      });

      // Scale to cover the card (center crop feel for calm full view)
      const scale = Math.max(canvas.width / baseImg.width, canvas.height / baseImg.height);
      const dw = baseImg.width * scale;
      const dh = baseImg.height * scale;
      const dx = (canvas.width - dw) / 2;
      const dy = (canvas.height - dh) / 2;
      ctx.drawImage(baseImg, dx, dy, dw, dh);

      // Very subtle artistic veil to keep the calm card feeling (not raw screenshot)
      const veil = ctx.createLinearGradient(0, canvas.height * 0.6, 0, canvas.height);
      veil.addColorStop(0, 'rgba(5,7,13,0.08)');
      veil.addColorStop(1, 'rgba(5,7,13,0.22)');
      ctx.fillStyle = veil;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Minimal poetic text (shifted right to leave clear space for bottom-left dragon watermark)
      // The dragon watermark owns the bottom-left corner; caption starts to its right.
      const captionX = 160; // after larger dragon width + padding
      ctx.fillStyle = 'rgba(233,237,245,0.75)';
      ctx.font = '600 26px system-ui';
      ctx.fillText(label, captionX, canvas.height - 68);

      ctx.font = '400 16px system-ui';
      ctx.fillStyle = 'rgba(170,180,199,0.65)';
      const extra = spectrum ? ` · ${spectrum}` : '';
      ctx.fillText(dateStr ? `Pinned ${dateStr}${extra}` : `A quiet moment worth keeping${extra}`, captionX, canvas.height - 42);

      // Watermarks last (on top, correct corners) using Imagine assets
      drawWatermarks(ctx, canvas.width, canvas.height, dragonImg, ladyImg);
    } else {
      // Pure calm artistic card for globe / other pins (no globe thumb ever)
      drawPrettyFallback(ctx, canvas.width, canvas.height, dragonImg, ladyImg);
    }

    return canvas.toDataURL('image/png');
  }

  function renderMyPins() {
    updateChipVisuals();   // safety net: always keep button visuals in sync with activeChip

    const grid = document.getElementById('pins-grid');
    const empty = document.getElementById('pins-empty');
    const noResults = document.getElementById('pins-no-results');
    const hint = document.getElementById('chip-hint');

    let pins = [];
    try {
      pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
    } catch {
      pins = [];
    }

    const searchInput = document.getElementById('pins-search');
    const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';

    const sortSelect = document.getElementById('pins-sort');
    const sortMode = sortSelect ? sortSelect.value : 'newest';

    // Filter pipeline: collection chip first, then search, then sort
    let filtered = applyCollectionFilter(pins, activeChip);

    if (searchTerm) {
      filtered = filtered.filter(p =>
        String(p.label || '').toLowerCase().includes(searchTerm) ||
        (p.note && String(p.note).toLowerCase().includes(searchTerm))
      );
    }

    let sorted = [...filtered];
    if (sortMode === 'newest') {
      sorted.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
    } else if (sortMode === 'oldest') {
      sorted.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
    } else if (sortMode === 'favorites') {
      sorted.sort((a, b) => (b.favorite ? 1 : 0) - (a.favorite ? 1 : 0) || new Date(b.createdAt) - new Date(a.createdAt));
    }

    grid.innerHTML = '';

    // Chip hint
    if (activeChip !== 'all') {
      const messages = {
        favorites: 'Your starred views',
        'sky-events': 'Moments you pinned from events',
        quiet: 'Some views wait patiently for you. They’ve been waiting a while.'
      };
      hint.textContent = messages[activeChip] || '';
      hint.classList.remove('hidden');
    } else {
      hint.classList.add('hidden');
    }

    if (pins.length === 0) {
      empty.classList.remove('hidden');
      noResults.classList.add('hidden');
      return;
    }

    empty.classList.add('hidden');

    if (sorted.length === 0 && searchTerm) {
      noResults.classList.remove('hidden');
      return;
    } else {
      noResults.classList.add('hidden');
    }

    // Rediscover strip — shown primarily when Quiet revisit chip is active (per handoff intent)
    const rediscover = document.getElementById('rediscover-strip');
    const rediscoverItems = document.getElementById('rediscover-items');

    if (activeChip === 'quiet') {
      const oldest = [...pins].sort((a, b) => new Date(a.updatedAt || a.createdAt) - new Date(b.updatedAt || b.createdAt)).slice(0, 3);

      if (oldest.length > 0) {
        rediscover.classList.remove('hidden');
        rediscoverItems.innerHTML = '';
        oldest.forEach(pin => {
          const el = document.createElement('div');
          el.className = 'px-3 py-1 rounded-lg border border-void-700 text-mist-300 hover:border-void-500 cursor-pointer text-sm';
          el.textContent = pin.label || 'Untitled';
          el.onclick = (e) => {
            // Light protection even though not inside main cards
            e.stopImmediatePropagation?.();
            localStorage.setItem('flyToPin', JSON.stringify({
              id: pin.id,
              viewState: pin.viewState
            }));
            window.location.href = base + 'globe';
          };
          rediscoverItems.appendChild(el);
        });
      } else {
        rediscover.classList.add('hidden');
      }
    } else {
      rediscover.classList.add('hidden');
    }

    sorted.forEach((pin) => {
      const card = document.createElement('div');
      const isFromSky = !!pin.sourceEventId;
      card.className = `group rounded-xl border border-void-700 bg-void-900 p-5 hover:border-void-500 hover:-translate-y-0.5 transition-all duration-200 shadow-sm cursor-pointer ${isFromSky ? 'border-l-2 border-l-emerald-700' : ''}`;

      // Thumbnail (real or gradient fallback)
      let thumbHTML = '';
      const viewState = pin.viewState || {};
      const lat = safeNumber(viewState.lat);
      const lng = safeNumber(viewState.lng);
      const altitude = safeNumber(viewState.altitude, 2.8);
      const label = escapeHtml(pin.label || 'Untitled Pin');
      const note = pin.note ? escapeHtml(pin.note) : '';

      if (pin.thumbnailData) {
        thumbHTML = `<img src="${escapeHtml(pin.thumbnailData)}" class="w-[52px] h-[38px] rounded-md object-cover flex-shrink-0 border border-void-700" />`;
      } else {
        const hue = Math.floor(((lat + 90) / 180) * 360);
        const sat = 38 + Math.floor(Math.abs(lng) % 35);
        const light = 32 + Math.floor(Math.abs(lat) % 18);
        thumbHTML = `<div style="width:52px;height:38px;border-radius:6px;background:linear-gradient(135deg, hsl(${hue},${sat}%,${light}%), hsl(${hue+30},${sat+10}%,${light-8}%));flex-shrink-0;border:1px solid #36415a;"></div>`;
      }

      const lastViewed = pin.updatedAt 
        ? `Last viewed ${Math.floor((Date.now() - new Date(pin.updatedAt).getTime()) / (1000*60*60*24))} days ago`
        : `Pinned ${new Date(pin.createdAt).toLocaleDateString()}`;

      card.innerHTML = `
        <div class="flex justify-between items-start">
          <div class="flex items-center gap-2 min-w-0">
            ${thumbHTML}
            <div class="min-w-0">
              <div class="font-medium text-mist-100 pin-label cursor-pointer hover:underline flex items-center gap-1.5">
                ${label}
                ${pin.favorite ? `<span class="text-yellow-400 text-sm">★</span>` : ''}
              </div>
              <div class="text-[10px] text-mist-500 mt-0.5">${lastViewed}</div>
            </div>
          </div>
          <div class="flex items-center gap-1">
            <button class="edit-btn text-xs px-2 py-0.5 rounded border border-void-600 text-mist-400 hover:text-mist-200" data-id="${pin.id}">Edit</button>
            <button class="share-btn text-xs px-2 py-0.5 rounded border border-void-600 text-mist-400 hover:text-mist-200" data-id="${pin.id}">Share</button>
            <button class="favorite-btn text-lg leading-none transition-colors ${pin.favorite ? 'text-yellow-400' : 'text-mist-400 hover:text-yellow-300'}" data-id="${pin.id}">★</button>
            <button class="delete-pin text-mist-400 hover:text-red-400/80 text-xl leading-none transition-colors" data-id="${pin.id}">×</button>
          </div>
        </div>
        ${note ? `<div class="mt-3 text-sm text-mist-300 pin-note cursor-pointer hover:underline line-clamp-2">${note}</div>` : ''}
        ${isFromSky ? `<div class="mt-2 text-[10px] text-emerald-400/70">from Sky Events</div>` : ''}
        <div class="mt-3 text-[10px] text-mist-500">lat ${lat.toFixed(2)} · lng ${lng.toFixed(2)}</div>
        <div class="edit-panel hidden mt-4 border-t border-void-700 pt-4"></div>
      `;

      // Click card → fly to view on globe + pass pin identity
      card.addEventListener('click', (e) => {
        if (e.target.classList.contains('delete-pin') || 
            e.target.classList.contains('favorite-btn') ||
            e.target.classList.contains('edit-btn') ||
            e.target.classList.contains('share-btn')) return;

        // Pass both the viewState and the specific pin ID so the globe knows exactly which pin we're viewing
        localStorage.setItem('flyToPin', JSON.stringify({
          id: pin.id,
          viewState: { lat, lng, altitude }
        }));
        window.location.href = base + 'globe';
      });

      // Delete
      card.querySelector('.delete-pin').addEventListener('click', (e) => {
        e.stopImmediatePropagation();
        if (!confirm('Remove this pin?')) return;
        const updated = pins.filter(p => p.id !== pin.id);
        localStorage.setItem('personalPins', JSON.stringify(updated));
        renderMyPins();
      });

      // Favorite toggle
      const favBtn = card.querySelector('.favorite-btn');
      if (favBtn) {
        favBtn.addEventListener('click', (e) => {
          e.stopImmediatePropagation();
          pin.favorite = !pin.favorite;
          const updated = pins.map(p => p.id === pin.id ? pin : p);
          localStorage.setItem('personalPins', JSON.stringify(updated));
          renderMyPins();
        });
      }

      // Share button (B.1) — direct like delete/favorite so it works on first click, no scope games
      const shareBtn = card.querySelector('.share-btn');
      if (shareBtn) {
        shareBtn.addEventListener('click', async (e) => {
          e.stopImmediatePropagation();
          try {
            const dataUrl = await createShareableImage(pin);
            const a = document.createElement('a');
            a.href = dataUrl;
            const safeLabel = (pin.label || 'Saved View').replace(/[^a-z0-9]/gi, '_');
            a.download = `dragon-lady-${safeLabel}.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
          } catch (err) {
            console.error('Share image failed', err);
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #5c3a3a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = 'Could not generate share image.';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2800);
          }
        });
      }

      // Edit button opens inline panel
      const editBtn = card.querySelector('.edit-btn');
      const editPanel = card.querySelector('.edit-panel');

      editBtn.addEventListener('click', (e) => {
        e.stopImmediatePropagation();
        editPanel.innerHTML = `
          <div class="space-y-3">
            <input type="text" value="${escapeHtml(pin.label || '')}" class="edit-label w-full px-3 py-2 rounded-lg border border-void-700 bg-void-950 text-mist-100 text-sm" />
            <textarea class="edit-note w-full px-3 py-2 rounded-lg border border-void-700 bg-void-950 text-mist-100 text-sm" rows="3">${escapeHtml(pin.note || '')}</textarea>
            <div class="flex gap-2">
              <button class="save-edit px-4 py-1.5 text-sm rounded-lg bg-signal-400 text-void-950 font-medium">Save</button>
              <button class="cancel-edit px-4 py-1.5 text-sm rounded-lg border border-void-700 text-mist-300">Cancel</button>
            </div>
          </div>
        `;
        editPanel.classList.remove('hidden');

        const saveBtn = editPanel.querySelector('.save-edit');
        const cancelBtn = editPanel.querySelector('.cancel-edit');

        saveBtn.addEventListener('click', () => {
          const newLabel = editPanel.querySelector('.edit-label').value.trim();
          const newNote = editPanel.querySelector('.edit-note').value.trim();
          if (newLabel) pin.label = newLabel;
          pin.note = newNote || undefined;
          const updated = pins.map(p => p.id === pin.id ? pin : p);
          localStorage.setItem('personalPins', JSON.stringify(updated));
          renderMyPins();
        });

        cancelBtn.addEventListener('click', () => {
          editPanel.classList.add('hidden');
          editPanel.innerHTML = '';
        });
      });

      grid.appendChild(card);
    });
  }

  function updateChipVisuals() {
    const chips = document.querySelectorAll('#pins-chips .chip');
    chips.forEach(c => {
      const isActive = c.dataset.chip === activeChip;

      // Clear all state classes first
      c.classList.remove('active', 'border-signal-400', 'bg-void-800', 'text-mist-100', 'border-void-700', 'text-mist-300');

      if (isActive) {
        // Active appearance
        c.classList.add('active', 'border-signal-400', 'bg-void-800', 'text-mist-100');
      } else {
        // Inactive appearance
        c.classList.add('border-void-700', 'bg-void-900', 'text-mist-300');
      }
    });
  }

  function setupMyPins() {
    // Chip handling
    const chips = document.querySelectorAll('#pins-chips .chip');
    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const chipType = chip.dataset.chip;

        if (activeChip === chipType) {
          activeChip = 'all';
        } else {
          activeChip = chipType;
        }

        updateChipVisuals();
        renderMyPins();
      });
    });

    // Save to vault (3A-write) — unified to existing /api/vault-pins endpoint
    const saveVaultBtn = document.getElementById('save-vault');
    if (saveVaultBtn) {
      saveVaultBtn.addEventListener('click', async () => {
        const pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
        try {
          const res = await fetch('/api/vault-pins', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pins, lastSynced: new Date().toISOString() })
          });
          if (res.ok) {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #36415a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = 'Saved to vault';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2400);
          } else {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #5c3a3a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = 'Vault save did not complete';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
          }
        } catch (e) {
          const toast = document.createElement('div');
          toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #5c3a3a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
          toast.textContent = 'Could not reach vault';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        }
      });
    }

    // Export
    const exportBtn = document.getElementById('export-pins');
    if (exportBtn) {
      exportBtn.addEventListener('click', () => {
        const pins = JSON.parse(localStorage.getItem('personalPins') || '[]');
        const date = new Date().toISOString().split('T')[0];
        const blob = new Blob([JSON.stringify(pins, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `dragon-lady-pins-${date}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      });
    }

    // Import
    const importInput = document.getElementById('import-pins');
    if (importInput) {
      importInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (event) => {
          try {
            const imported = JSON.parse(event.target.result);
            if (!Array.isArray(imported)) {
              const toast = document.createElement('div');
              toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #5c3a3a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
              toast.textContent = 'File does not contain a valid pins array.';
              document.body.appendChild(toast);
              setTimeout(() => toast.remove(), 3000);
              return;
            }

            let current = [];
            try {
              current = JSON.parse(localStorage.getItem('personalPins') || '[]');
            } catch {}

            const existingIds = new Set(current.map(p => p.id));
            let added = 0;

            imported.forEach(pin => {
              if (pin && pin.id && !existingIds.has(pin.id)) {
                current.push(pin);
                existingIds.add(pin.id);
                added++;
              }
            });

            localStorage.setItem('personalPins', JSON.stringify(current));
            renderMyPins();

            const msg = added === 1 ? '1 pin imported' : `${added} pins imported`;
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #36415a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);

          } catch (err) {
            const toast = document.createElement('div');
            toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#0f1420;border:1px solid #5c3a3a;color:#e9edf5;padding:10px 22px;border-radius:9999px;font-size:13px;';
            toast.textContent = 'Could not read the file. Please make sure it is a valid pins backup.';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
          }
        };
        reader.readAsText(file);
        e.target.value = '';
      });
    }

    renderMyPins();
    updateChipVisuals();       // force correct initial highlighting
    checkVaultAndShowBanner();

    const searchInput = document.getElementById('pins-search');
    const clearBtn = document.getElementById('clear-search');
    const sortSelect = document.getElementById('pins-sort');

    if (searchInput) {
      searchInput.addEventListener('input', () => renderMyPins());
    }

    if (clearBtn && searchInput) {
      clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        renderMyPins();
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', () => renderMyPins());
    }
  }

  async function checkVaultAndShowBanner() {
    const banner = document.getElementById('vault-banner');
    if (!banner || localStorage.getItem('vaultMigrationBannerDismissed')) return;

    try {
      const res = await fetch('/api/vault-pins');
      if (!res.ok) return;

      const vaultData = await res.json();
      if (!Array.isArray(vaultData.pins) || vaultData.pins.length === 0) return;

      const localPins = JSON.parse(localStorage.getItem('personalPins') || '[]');

      // Restored robust max-date scan (no more fragile pins[0] reliance)
      const latestLocal = localPins.reduce((max, p) => {
        const d = new Date(p.updatedAt || p.createdAt || 0);
        return d > max ? d : max;
      }, new Date(0));

      const vaultNewer = vaultData.lastSynced && (!localPins.length || new Date(vaultData.lastSynced) > latestLocal);

      if (vaultNewer || localPins.length === 0) {
        banner.classList.remove('hidden');

        const bringHome = document.getElementById('bring-home');
        const notNow = document.getElementById('not-now');

        if (bringHome) {
          bringHome.onclick = (e) => {
            e.stopImmediatePropagation();
            let current = JSON.parse(localStorage.getItem('personalPins') || '[]');
            const existingIds = new Set(current.map(p => p.id));
            let added = 0;

            vaultData.pins.forEach(pin => {
              if (pin && pin.id && !existingIds.has(pin.id)) {
                current.push(pin);
                existingIds.add(pin.id);
                added++;
              }
            });

            localStorage.setItem('personalPins', JSON.stringify(current));
            localStorage.setItem('vaultMigrationBannerDismissed', 'true');
            banner.classList.add('hidden');
            renderMyPins();
          };
        }

        if (notNow) {
          notNow.onclick = (e) => {
            e.stopImmediatePropagation();
            localStorage.setItem('vaultMigrationBannerDismissed', 'true');
            banner.classList.add('hidden');
          };
        }
      }
    } catch (e) {}
  }

  setupMyPins();
  </script>
