---
import '@/styles/global.css';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#05070d" />
  <title>The Globe · Dragon Lady’s Observatory</title>
  <script is:inline src="https://web.wwtassets.org/engine/7/wwtsdk.js"></script>
  <style>
    :root {
      color-scheme: dark;
      --mist: #e9edf5;
      --soft: #aab4c7;
      --dim: #6b7790;
      --panel: rgba(8, 12, 22, 0.78);
      --line: rgba(137, 231, 255, 0.24);
      --signal: #6fd3e2;
    }

    html,
    body {
      height: 100%;
      margin: 0;
      overflow: hidden;
      background: #05070d;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .stage {
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at 14% 18%, rgba(111, 211, 226, 0.17), transparent 24%),
        radial-gradient(circle at 84% 78%, rgba(106, 90, 205, 0.20), transparent 28%),
        #05070d;
    }

    #wwt-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      background: #000;
    }

    .aurora {
      pointer-events: none;
      position: absolute;
      inset: -12%;
      background:
        conic-gradient(from 218deg at 50% 50%,
          transparent 0deg,
          rgba(82, 255, 210, 0.14) 42deg,
          rgba(95, 141, 255, 0.18) 76deg,
          transparent 116deg,
          transparent 208deg,
          rgba(146, 92, 255, 0.14) 252deg,
          rgba(91, 231, 255, 0.11) 292deg,
          transparent 340deg);
      filter: blur(34px) saturate(1.3);
      opacity: 0.72;
      mix-blend-mode: screen;
    }

    .topbar {
      position: fixed;
      left: 16px;
      right: 16px;
      top: 14px;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .brand,
    .controls,
    .side-panel {
      border: 1px solid var(--line);
      background: var(--panel);
      backdrop-filter: blur(12px);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.32);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      min-height: 42px;
      padding: 0 13px;
      color: var(--mist);
    }

    .brand strong {
      display: block;
      font-size: 14px;
      font-weight: 650;
      letter-spacing: 0;
      line-height: 1.1;
    }

    .brand a {
      color: var(--signal);
      font-size: 12px;
      text-decoration: none;
    }

    .controls {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px;
    }

    button,
    input {
      height: 34px;
      border-radius: 6px;
      border: 1px solid rgba(170, 180, 199, 0.22);
      background: rgba(5, 7, 13, 0.76);
      color: var(--mist);
      font: inherit;
      font-size: 12px;
      letter-spacing: 0;
    }

    button {
      cursor: pointer;
      padding: 0 12px;
      font-weight: 600;
    }

    button:hover {
      border-color: rgba(111, 211, 226, 0.7);
      color: #ffffff;
    }

    button.primary {
      border-color: rgba(111, 211, 226, 0.72);
      background: rgba(111, 211, 226, 0.18);
      color: #dffaff;
    }

    input {
      width: 96px;
      padding: 0 9px;
      color: var(--soft);
    }

    .side-panel {
      position: fixed;
      left: 16px;
      top: 76px;
      z-index: 20;
      width: min(330px, calc(100vw - 32px));
      box-sizing: border-box;
      padding: 14px;
      color: var(--soft);
    }

    .panel-title {
      color: var(--mist);
      font-size: 13px;
      font-weight: 650;
      line-height: 1.2;
      margin-bottom: 10px;
    }

    .field-stack {
      display: grid;
      gap: 8px;
    }

    .wide-input,
    .side-panel input {
      width: 100%;
      box-sizing: border-box;
    }

    .input-row,
    .button-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .button-row button,
    .input-row input {
      min-width: 0;
    }

    .panel-note {
      margin-top: 10px;
      color: var(--dim);
      font-size: 11px;
      line-height: 1.35;
    }

    .pinned-list {
      display: grid;
      gap: 6px;
      margin-top: 10px;
      max-height: 188px;
      overflow: auto;
      padding-right: 2px;
    }

    :global(.pin-row) {
      height: auto;
      min-height: 34px;
      width: 100%;
      padding: 7px 9px;
      text-align: left;
      line-height: 1.25;
      white-space: normal;
    }

    :global(.pin-row small) {
      display: block;
      color: var(--dim);
      font-size: 10px;
      margin-top: 2px;
    }

    .status {
      position: fixed;
      left: 16px;
      bottom: 16px;
      z-index: 20;
      max-width: min(520px, calc(100vw - 32px));
      border: 1px solid rgba(170, 180, 199, 0.18);
      background: rgba(8, 12, 22, 0.72);
      color: var(--soft);
      padding: 9px 12px;
      font-size: 12px;
      line-height: 1.4;
      backdrop-filter: blur(12px);
    }

    .status strong {
      color: var(--mist);
      font-weight: 650;
    }

    @media (max-width: 760px) {
      .topbar {
        align-items: stretch;
        flex-direction: column;
      }

      .brand,
      .controls {
        width: 100%;
        box-sizing: border-box;
      }

      .controls {
        flex-wrap: wrap;
      }

	      input {
	        flex: 1 1 104px;
	      }

	      .side-panel {
	        top: 132px;
	      }
	    }
	  </style>
	</head>
<body>
  <main class="stage">
    <div id="wwt-canvas" aria-label="WorldWide Telescope Earth viewer"></div>
    <div class="aurora" aria-hidden="true"></div>
  </main>

  <div class="topbar">
    <div class="brand">
      <strong>The Globe</strong>
      <a href={base}>console</a>
      <a href={base + 'observatory'}>observatory</a>
    </div>

	    <div class="controls">
	      <button id="earth-btn" class="primary" type="button">Earth</button>
	      <button id="full-btn" type="button">Full</button>
	    </div>
	  </div>

	  <aside class="side-panel" aria-label="Location search">
	    <div class="panel-title">Location Search</div>
	    <div class="field-stack">
	      <input id="loc-name" class="wide-input" type="search" autocomplete="off" placeholder="city, state, country" aria-label="Search for a location" />
	      <div class="button-row">
	        <button id="resolve-btn" class="primary" type="button">Resolve</button>
	        <button id="sky-btn" type="button">Sky Here</button>
	      </div>
	      <div class="input-row">
	        <input id="lat-input" type="number" inputmode="decimal" step="0.0001" min="-90" max="90" placeholder="lat" aria-label="Latitude" />
	        <input id="lng-input" type="number" inputmode="decimal" step="0.0001" min="-180" max="180" placeholder="lng" aria-label="Longitude" />
	      </div>
	    </div>
	    <div id="location-status" class="panel-note">Search a place, enter coordinates, or choose a saved pin.</div>
	    <div id="pinned-list" class="pinned-list" aria-label="Saved pinned locations"></div>
	  </aside>

	  <div id="status" class="status"><strong>Loading WWT.</strong> Preparing the Earth view.</div>

  <script is:inline define:vars={{ base }}>
    (function () {
      const EARTH_IMAGESET = 'Bing Maps Aerial';
      const status = document.getElementById('status');
      const canvas = document.getElementById('wwt-canvas');
      const earthBtn = document.getElementById('earth-btn');
      const skyBtn = document.getElementById('sky-btn');
	      const fullBtn = document.getElementById('full-btn');
	      const latInput = document.getElementById('lat-input');
	      const lngInput = document.getElementById('lng-input');
	      const locName = document.getElementById('loc-name');
	      const resolveBtn = document.getElementById('resolve-btn');
	      const locationStatus = document.getElementById('location-status');
	      const pinnedList = document.getElementById('pinned-list');
	      let scriptInterface = null;
	      let wwt = null;

      function setStatus(title, detail) {
        if (!status) return;
        status.innerHTML = '<strong>' + title + '</strong>' + (detail ? ' ' + detail : '');
      }

	      function parseNumber(input, min, max) {
	        const value = Number(input.value);
	        if (!Number.isFinite(value) || value < min || value > max) return null;
	        return value;
	      }

	      function setLocationStatus(message) {
	        if (locationStatus) locationStatus.textContent = message;
	      }

	      function setLocation(lat, lng, label) {
	        if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
	        latInput.value = lat.toFixed(4);
	        lngInput.value = lng.toFixed(4);
	        if (label && locName) locName.value = label;
	        setLocationStatus('Ready: ' + lat.toFixed(4) + ', ' + lng.toFixed(4));
	      }

	      function readUrlLocation() {
	        try {
	          const url = new URL(window.location.href);
	          if (url.searchParams.has('lat') && url.searchParams.has('lng')) {
	            const lat = Number(url.searchParams.get('lat'));
	            const lng = Number(url.searchParams.get('lng'));
	            if (Number.isFinite(lat) && Number.isFinite(lng)) {
	              setLocation(lat, lng, 'Location handoff');
	            }
	          }
	        } catch (_) {}

        try {
          const fly = localStorage.getItem('flyToPin');
          if (!fly) return;
          const parsed = JSON.parse(fly);
          if (parsed && parsed.viewState) {
            const lat = Number(parsed.viewState.lat);
	            const lng = Number(parsed.viewState.lng);
	            if (Number.isFinite(lat) && Number.isFinite(lng)) {
	              setLocation(lat, lng, parsed.title || parsed.name || 'Saved pin');
	            }
	            localStorage.removeItem('flyToPin');
	          }
	        } catch (_) {}
	      }

	      async function resolveLocationName() {
	        const query = locName ? locName.value.trim() : '';
	        if (!query) {
	          setLocationStatus('Enter a place name first.');
	          return;
	        }

	        setLocationStatus('Resolving location...');
	        try {
	          const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(query));
	          if (!response.ok) throw new Error('Search failed with HTTP ' + response.status);
	          const results = await response.json();
	          const match = Array.isArray(results) ? results[0] : null;
	          if (!match) {
	            setLocationStatus('No match found. Try a city, state, or country.');
	            return;
	          }

	          const lat = Number(match.lat);
	          const lng = Number(match.lon);
	          if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
	            setLocationStatus('That match did not include usable coordinates.');
	            return;
	          }

	          setLocation(lat, lng, match.display_name || query);
	          setStatus('Location resolved.', 'Use Sky Here to open the observatory view for this position.');
	        } catch (error) {
	          console.error('[globe] Location search failed', error);
	          setLocationStatus('Location search failed. Manual lat/lng still works.');
	        }
	      }

	      async function loadSavedPins() {
	        if (!pinnedList) return;
	        pinnedList.textContent = 'Loading saved pins...';

	        try {
	          const apiBase = base || '/';
	          const response = await fetch(apiBase + 'api/vault-pins');
	          const data = await response.json();
	          const pins = ((data && data.pins) || (Array.isArray(data) ? data : []))
	            .filter((pin) => pin && pin.viewState && Number.isFinite(Number(pin.viewState.lat)) && Number.isFinite(Number(pin.viewState.lng)))
	            .slice(0, 8);

	          pinnedList.innerHTML = '';
	          if (!pins.length) {
	            pinnedList.textContent = 'No saved pins found yet.';
	            return;
	          }

	          pins.forEach((pin) => {
	            const lat = Number(pin.viewState.lat);
	            const lng = Number(pin.viewState.lng);
	            const label = pin.title || pin.name || pin.label || (pin.id ? 'Pin ' + String(pin.id).slice(0, 8) : 'Saved pin');
	            const row = document.createElement('button');
	            const coords = document.createElement('small');
	            row.type = 'button';
	            row.className = 'pin-row';
	            row.textContent = label;
	            coords.textContent = lat.toFixed(4) + ', ' + lng.toFixed(4);
	            row.appendChild(coords);
	            row.addEventListener('click', () => setLocation(lat, lng, label));
	            pinnedList.appendChild(row);
	          });
	        } catch (error) {
	          console.error('[globe] Saved pins unavailable', error);
	          pinnedList.textContent = 'Saved pins unavailable. Manual search still works.';
	        }
	      }

      function activateEarthMode() {
        if (!wwt) {
          setStatus('Still loading.', 'WWT is not ready yet.');
          return;
        }

        try {
          wwt.setBackgroundImageByName(EARTH_IMAGESET);
          if (typeof wwt.setForegroundImageByName === 'function') {
            wwt.setForegroundImageByName(EARTH_IMAGESET);
          }
          setStatus('Earth mode requested.', 'Using WWT background "' + EARTH_IMAGESET + '". Drag to spin; wheel to zoom.');
        } catch (error) {
          console.error('[globe] Could not switch WWT to Earth mode', error);
          setStatus('Earth mode failed.', error && error.message ? error.message : 'Check the console.');
        }
      }

	      function openSkyHere() {
	        const lat = parseNumber(latInput, -90, 90);
	        const lng = parseNumber(lngInput, -180, 180);
	        if (lat === null || lng === null) {
	          setStatus('Set a location.', 'Enter latitude and longitude first.');
	          setLocationStatus('Latitude must be -90 to 90. Longitude must be -180 to 180.');
	          return;
	        }

        window.location.href = base + 'observatory?lat=' + lat.toFixed(4) + '&lng=' + lng.toFixed(4);
      }

      function toggleFullscreen() {
        const target = document.documentElement;
        if (document.fullscreenElement) {
          document.exitFullscreen().catch(() => {});
          return;
        }
        target.requestFullscreen().catch(() => {});
      }

      function onReady() {
        wwt = window.wwtlib && window.wwtlib.WWTControl ? window.wwtlib.WWTControl.singleton : null;
        if (!wwt) {
          setStatus('WWT loaded without a control.', 'The hosted engine did not expose WWTControl.');
          return;
        }

        setStatus('WWT ready.', 'Switching to Earth mode.');
        activateEarthMode();
      }

	      function init() {
	        readUrlLocation();
	        loadSavedPins();

	        if (!window.wwtlib || !window.wwtlib.WWTControlBuilder) {
	          setStatus('WWT engine did not load.', 'Check network access to web.wwtassets.org.');
          return;
        }

        try {
          const builder = new window.wwtlib.WWTControlBuilder('wwt-canvas');
          builder.startRenderLoop(true);
          scriptInterface = builder.create();
          if (scriptInterface && typeof scriptInterface.add_ready === 'function') {
            scriptInterface.add_ready(onReady);
          } else {
            setTimeout(onReady, 1400);
          }
        } catch (error) {
          console.error('[globe] WWT initialization failed', error);
          setStatus('WWT initialization failed.', error && error.message ? error.message : 'Check the console.');
        }
      }

	      earthBtn.addEventListener('click', activateEarthMode);
	      skyBtn.addEventListener('click', openSkyHere);
	      fullBtn.addEventListener('click', toggleFullscreen);
	      resolveBtn.addEventListener('click', resolveLocationName);
	      locName.addEventListener('keydown', (event) => {
	        if (event.key === 'Enter') {
	          event.preventDefault();
	          resolveLocationName();
	        }
	      });

      if (document.readyState === 'complete') init();
      else window.addEventListener('load', init);
    })();
  </script>
</body>
</html>
