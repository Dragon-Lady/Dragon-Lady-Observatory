# Copy to .env and fill in. .env is gitignored — never commit credentials.

# Space-Track.org (free registration at space-track.org)
# THE authoritative source for orbital catalog, conjunctions, decay.
SPACETRACK_USER=your_email@example.com
SPACETRACK_PASS=your_password

# Launch Library 2 (optional — public tier works without a key)
# Register at thespacedevs.com for a free key to raise rate limits.
LL2_API_KEY=
